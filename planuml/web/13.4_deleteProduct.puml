@startuml 13.4_deleteProduct
hide footbox
title Delete Product

actor User as "Users"
boundary ProductPage as View
participant ":ProductRoute" as Route
control "AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Click "Delete" on a product
activate View
activate User
View --> User : 2. Show confirmation dialog
User -> View : 3. Confirm delete

    View -> Route : 4. DELETE /products/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 6. Forward DeleteProductRequest(productId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process product deletion
    activate Service

alt Product not found
    Service -> Model : 8.1. Find product by ID
    activate Model

    Model -> Database : 8.1.1. Retrieve product data by ID
    activate Database
    Database --> Model : 8.1.2. Result (null)
    deactivate Database

    Model --> Service : 8.1.3. Return not found
    deactivate Model

        Service --> Controller : 8.1.4. Return not found result
        Controller --> Route : 8.1.5. Return 404 Not Found + message
        Route --> View : 8.1.6. Show error: "Product not found"
else Product exists
        Service -> Model : 8.2. Delete product by ID
        activate Model

        Model -> Database : 8.2.1. Persist deletion
        activate Database
        Database --> Model : 8.2.2. Delete success
        deactivate Database

        Model --> Service : 8.2.3. Return deletion result
        deactivate Model

        Service --> Controller : 8.2.4. Return DeleteProductResponse
        deactivate Service
        Controller --> Route : 8.2.5. Return 200 OK + success message
        deactivate Controller
        Route --> View : 8.2.6. Show delete success
        deactivate Route
end

View --> User : 9. Display result (success or error)
deactivate View
deactivate User
@enduml
