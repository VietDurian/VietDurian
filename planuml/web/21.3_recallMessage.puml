@startuml RecallMessage

actor User as "Users"
boundary "ConversationDetailPage" as View 
participant ":chatRoute" as Route 
control "authMiddleware" as Auth 
control "chatController" as Controller 
participant ":chatService" as Service 
entity "messageModel" as Model 
database "MongoDB" as MongoDB 
participant "Socket Server" as Socket 
hide footbox

    User -> View: 1. Click recall specific message
    activate User
    activate View

    View -> View: 2. Show confirmation dialog
    activate View
    deactivate View

    opt Cancel Recall
        View --> User: 2.1. Cancel recall
    end

    User -> View: 3. Confirm recall

    View -> Route: 4. PUT /api/v1/chat/message/{messageId}
    activate Route

    Route -> Auth: 5. authenticateUser(req, res, next)
    activate Auth
    
    ref over User, MongoDB : Verifies token

    Auth --> Route: 6. authentication success
    deactivate Auth

    Route -> Controller: 7. deleteMessage(req, res)
    deactivate Route
    activate Controller

    Controller -> Service: 8. deleteMessage(messageId)
    activate Service

    Service -> Model: 9. deleteMessage(messageId)
    activate Model

    Model -> MongoDB: 10. ExecuteQuery()
    activate MongoDB
    MongoDB --> Model: 11. return updated message
    deactivate MongoDB

    Model --> Service: 12. return updated message
    deactivate Model

    Service --> Controller: 13. return updated message
    deactivate Service

    Controller -> Controller: 14. checkRecipientRole(updatedMessage)
    activate Controller
    deactivate Controller

    par Emit to other user
        Controller -> Socket: 14.1. emit 'message_recalled' to other user
        activate Socket
        Socket --> View: 14.1.1. broadcast to other user client
        deactivate Socket
    else Emit to admin
        Controller -> Socket: 14.2. emit 'message_recalled' to admin
        deactivate Controller
        activate Socket
        Socket --> View: 14.2.1. broadcast to admin client
        deactivate Socket
    end

    View --> User: 15. display updated message with (recalled) label
    deactivate View
    deactivate User

@enduml
