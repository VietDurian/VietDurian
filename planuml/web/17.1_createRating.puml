@startuml 17.1_createRating
hide footbox
title Create Rating

actor User
boundary RatingPage as View
control RatingRoute as Route
participant ":AuthMiddleware" as Middleware
control "RatingController" as Controller
participant ":RatingService" as Service
participant ":RatingModel" as Model
database Database as Database


User -> View : 1. Input rating fields
activate View
View -> View : 2. Validate input

opt Check validation
    View --> User : 2.1. Show validation error
end

    View -> Route : 3. POST /ratings/add
    activate Route

    Route -> Middleware : 4. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 5. Authentication success
    Middleware -> Controller : 6. Forward CreateRatingRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process rating creation
    activate Service

alt Rating exists
    Service -> Model : 7.1. Check conflicts
    activate Model

    Model -> Database : 7.1.1. Check existing rating
    activate Database
    Database --> Model : 7.1.2. Conflict result\n(true / false)
    deactivate Database

    Model --> Service : 7.1.3. Return conflict state
    deactivate Model

        Service --> Controller : 7.1.4. Return rating already exists
        Controller --> Route : 7.1.5. Return error response
        Route --> View : 7.1.6. Show error
else Rating is valid
        Service -> Model : 7.2. Save new rating
        activate Model

        Model -> Database : 7.2.1. Persist rating data
        activate Database
        Database --> Model : 7.2.2. Created
        deactivate Database

        Model --> Service : 7.2.3. Return created entity
        deactivate Model

        Service --> Controller : 7.2.4. Return RatingResponse
        deactivate Service
        Controller --> Route : 7.2.5. Return 200 OK + rating data
        deactivate Controller
        Route --> View : 7.2.6. Show success
        deactivate Route
end

View --> User : 8. Display form result (success or error)
deactivate View
@enduml
