@startuml 12.3_filterUser
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control userManagementRoute as Route
participant ":authMiddleware" as Middleware
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Select filter criteria (role, status, etc.)
activate UI
User -> UI : 2. Click apply filter button
UI -> UI : 3. Validate filter input
activate UI
deactivate UI
opt validation error
    UI --> User : 3.1 Display error message
end
UI -> Route : 4. GET /userManagement/filter?role=role&status=status
activate Route
Route -> Middleware : 5. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 6. handleFilterUser(userInfo, filters)
deactivate Middleware
activate Controller
Controller -> Controller : 7. validateInput()
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 7.1 Return error
    Route --> UI : 7.2 Show error message
    UI --> User : 7.3 Display error message
end
Controller -> Service : 8. filterUser(filters)
activate Service
Service -> Model : 9. findByFilters(filters)
activate Model
Model -> DB : 10. excute query with filters
activate DB
DB --> Model : 11. Return matching user documents
deactivate DB
Model --> Service : 12. Return matching user documents
deactivate Model
Service -> Service : 13. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 13.1 Return error
    Controller --> Route : 13.2 Return error info
    Route --> UI : 13.3 Show error message
    UI --> User : 13.4 Display error message
end
Service -> Service : 14. mapToUserDTOList()
activate Service
deactivate Service
Service --> Controller : 15. Return success
deactivate Service
Controller --> Route : 16. Return success
deactivate Controller
Route --> UI : 17. Return success
deactivate Route
UI --> User : 18. Display filtered users
deactivate UI
deactivate User

@enduml
