@startuml 17.3_updateRating
hide footbox
title Update Rating

actor User
boundary EditRatingPage as View
control RatingRoute as Route
participant ":AuthMiddleware" as Middleware
control "RatingController" as Controller
participant ":RatingService" as Service
participant ":RatingModel" as Model
database Database as Database

User -> View : 1. Open rating edit form
activate View

User -> View : 2. Edit rating fields and submit
View -> View : 3. Validate form input

opt Check validation
    View --> User : 3.1. Show validation error
end

    View -> Route : 4. PUT /ratings/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 6. Authentication success
    Middleware -> Controller : 7. Forward UpdateRatingRequest(id, payload)
    deactivate Middleware
    activate Controller

    Controller -> Service : 8. Process rating update
    activate Service

alt Rating not found
    Service -> Model : 9.1. Find rating by ID
    activate Model

    Model -> Database : 9.1.1. Retrieve rating data by ID
    activate Database
    Database --> Model : 9.1.2. Result (null)
    deactivate Database

    Model --> Service : 9.1.3. Return not found
    deactivate Model

        Service --> Controller : 9.1.4. Return not found result
        Controller --> Route : 9.1.5. Return 404 Not Found + message
        Route --> View : 9.1.6. Show error: "Rating not found"
else Rating exists
        Service -> Model : 9.2. Update rating fields
        activate Model

        Model -> Database : 9.2.1. Persist updated rating data
        activate Database
        Database --> Model : 9.2.2. Update success
        deactivate Database

        Model --> Service : 9.2.3. Return updated entity
        deactivate Model

        Service --> Controller : 9.2.4. Return UpdateRatingResponse
        deactivate Service
        Controller --> Route : 9.2.5. Return 200 OK + updated rating data
        deactivate Controller
        Route --> View : 9.2.6. Show success message
        deactivate Route
end

View --> User : 10. Display result (success or error)
deactivate View
@enduml
