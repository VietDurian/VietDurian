@startuml EditProfile

actor User as "Users"
boundary "Profile Page" as View 
participant ":authRoute" as Route 
control "authMiddleware" as Auth 
control "authController" as Controller 
participant ":authService" as Service 
entity "userModel" as Model 
database "MongoDB" as MongoDB
hide footbox

User -> View: 1. Click "Edit"
activate View
activate User
User -> View: 2. Edit avatar, gender, height, weight, dob.

View -> View: 3. Validate input
activate View
deactivate View

opt Invalid input
    View --> User: 3.1. Display "Invalid input information"
end

View -> Route: 4. POST /api/v1/auth/profile
activate Route
Route -> Auth: 5. authenticateUser(req, res, next)
activate Auth
ref over User, MongoDB : Verifies token

Auth --> Route: 6. authentication success
deactivate Auth

Route -> Controller: 7. editProfile(req, res)
activate Controller

    Controller -> Service: 8. editProfile(userId, profileData)
    activate Service

    Service -> Model: 9. editUserById(userId, profileData)
    activate Model

    Model -> MongoDB: 10. ExecuteQuery()
    activate MongoDB
    MongoDB --> Model: 11. Return result
    deactivate MongoDB

    Model --> Service: 12. Return update result
    deactivate Model

    Service -> Service: 13. checkUpdateProfile()
    activate Service
    deactivate Service

alt Update Failed
    Service --> Controller: 13.1. Return error
    Controller --> Route: 13.1.1 Return error info
    Route --> View: 13.1.2. Show "Update failed"
    View --> User: 13.1.3. Display error message
else Update Success
    Service --> Controller: 13.2. Return success
    deactivate Service
    Controller --> Route: 13.2.1. Return success
    deactivate Controller
    Route --> View: 13.2.2. Return success
    deactivate Route
    View --> User: 13.2.3. Display updated profile
    deactivate View
    deactivate User
end
@enduml
