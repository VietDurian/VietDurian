@startuml 13.8_contactToBuy
hide footbox
title Contact To Buy

actor User as "Users"
boundary ProductDetailPage as View
participant ":ProductRoute" as Route
control "AuthMiddleware" as Middleware
control "ContactController" as Controller
participant ":ContactService" as Service
entity "ContactModel" as Model
database Database as Database

User -> View : 1. Click "Contact to buy"
activate View
activate User
View -> View : 2. Open contact modal\n(name, phone, message, quantity)

User -> View : 3. Fill contact info and submit
View -> View : 4. Validate input\n(required fields, phone format, quantity > 0)

opt Check validation
    View --> User : 4.1. Show validation error
end

    View -> Route : 5. POST /contacts/buy\n{ productId, name, phone, message, quantity }
    activate Route

    Route -> Middleware : 6. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 7. Forward ContactToBuyRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 8. Process contact to buy request
    activate Service

alt Product not found / unavailable
    Service -> Model : 9.1. Check product availability
    activate Model

    Model -> Database : 9.1.1. Retrieve product status by ID
    activate Database
    Database --> Model : 9.1.2. Result
    deactivate Database

    Model --> Service : 9.1.3. Return invalid product state
    deactivate Model

        Service --> Controller : 9.1.4. Return error result
        Controller --> Route : 9.1.5. Return 400/404 + message
        Route --> View : 9.1.6. Show error
else Product valid
        Service -> Model : 9.2. Create contact request record
        activate Model

        Model -> Database : 9.2.1. Persist contact request
        activate Database
        Database --> Model : 9.2.2. Created
        deactivate Database

        Model --> Service : 9.2.3. Return created contact request
        deactivate Model

        Service --> Controller : 9.2.4. Return ContactToBuyResponse
        deactivate Service
        Controller --> Route : 9.2.5. Return 200 OK + success message
        deactivate Controller
        Route --> View : 9.2.6. Show success
        deactivate Route
end

View --> User : 10. Display result (success or error)
deactivate View
deactivate User
@enduml
