@startuml ViewReportList

actor Admin
boundary "AdminDashboard" as View
participant ":reportRoute" as Route
control ":authMiddleware" as Auth
control "reportController" as Controller 
participant ":reportService" as Service 
entity "reportModel" as Model 
database "MongoDB" as MongoDB 
hide footbox

Admin -> View: 1. Click "Report Management"
activate Admin
activate View

View -> Route: 2. GET /api/v1/report
activate Route

Route -> Auth: 3. authenticateUser(req, res, next)
activate Auth
ref over Admin, MongoDB : Verifies token

Auth --> Route: 4. authentication success
deactivate Auth

Route -> Controller: 5. getAllReport(req, res)
activate Controller

Controller -> Service: 6. getAllReport()
activate Service

Service -> Model: 7. getAllReport()
activate Model
Model -> MongoDB: 8. Query all reports
activate MongoDB
MongoDB --> Model: 9. Return report list
deactivate MongoDB
Model --> Service: 10. Return report list
deactivate Model

Service --> Service: 11. checkEmptyResult()
activate Service
deactivate Service

alt Reports available
    Service --> Controller: 11.1. Return reports
    Controller --> Route: 11.1.1. Return 200 OK 
    Route --> View: 11.1.2. Render report list
    View --> Admin: 11.1.3. Show reports with user & Blog details
else Report list empty
    Service --> Controller: 11.2. Return empty result
    deactivate Service
    Controller --> Route: 11.2.1. Return 200 OK 
    deactivate Controller
    Route --> View: 11.2.2. Show "Report list is empty"
    deactivate Route
    View --> Admin: 11.2.3. Display empty list message
    deactivate View
    deactivate Admin
end
@enduml
