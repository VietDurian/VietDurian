@startuml 12.7_confirmRejectAccount
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Users
boundary AccountApprovalPage as UI
control permissionAccountController as Controller
participant ":permissionAccountService" as Service
participant ":permissionAccountModel" as Model
database Database as DB

activate Users
Users -> UI : 1. Open account approval page
activate UI
Users -> UI : 2. Choose decision (confirm/reject)
Users -> UI : 3. Click submit decision
UI -> UI : 4. Validate input
activate UI
deactivate UI
opt Validation error
    UI --> Users : 4.1 Display validation error
end

UI -> Controller : 5. POST /permission/accounts/:accountId/decision
activate Controller
Controller -> Controller : 6. validateInput()
activate Controller
deactivate Controller
opt invalid input
    Controller --> UI : 6.1 Return error
    UI --> Users : 6.2 Display error message
else input valid
    Controller -> Service : 7. decideAccountPermission(accountId, decision)
    activate Service
    Service -> Model : 8. findById(accountId)
    activate Model
    Model -> DB : 9. findOne()
    activate DB
    DB --> Model : 10. Return account request (or null)
    deactivate DB
    Model --> Service : 11. Return result
    deactivate Model

    Service -> Service : 12. checkNotFound()
    activate Service
    deactivate Service
    opt account request not found
        Service --> Controller : 12.1 Return error: not found
        Controller --> UI : 12.2 Return error
        UI --> Users : 12.3 Display error: request not found
    else found
        Service -> Service : 13. validateDecision()
        activate Service
        deactivate Service
        opt invalid decision
            Service --> Controller : 13.1 Return error: invalid decision
            Controller --> UI : 13.2 Return error
            UI --> Users : 13.3 Display error: invalid decision
        else decision valid
            alt decision = confirm
                Service -> Model : 14. updatePermissionStatus(accountId, APPROVED)
                activate Model
                Model -> DB : 15. updateOne()
                activate DB
                DB --> Model : 16. Return update result
                deactivate DB
                Model --> Service : 17. Return update result
                deactivate Model
                Service -> Service : 18. mapToApprovalDTO()
                activate Service
                deactivate Service
                Service --> Controller : 19. Return success: approved
                Controller --> UI : 20. Return success: approved
                UI --> Users : 21. Show approval confirmation
            else decision = reject
                Service -> Model : 14.1 updatePermissionStatus(accountId, REJECTED)
                activate Model
                Model -> DB : 15.1 updateOne()
                activate DB
                DB --> Model : 16.1 Return update result
                deactivate DB
                Model --> Service : 17.1 Return update result
                deactivate Model
                Service -> Service : 18.1 mapToRejectionDTO()
                activate Service
                deactivate Service
                Service --> Controller : 19.1 Return success: rejected
                deactivate Service
                Controller --> UI : 20.1 Return success: rejected
                deactivate Controller
                UI --> Users : 21.1 Show rejection confirmation
                deactivate UI
                deactivate Users
            end
        end
    end
end

@enduml