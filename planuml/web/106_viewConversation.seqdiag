actor "Users" as User
boundary "ChatPage" as View
control "messageController" as Controller
participant ":messageService" as Service
participant ":messageModel" as Model
database Database


User -> View : 1. Click "Chat" icon on product/post page or navbar
activate View
activate User

View -> Controller : 2. Get conversation request
activate Controller

Controller -> Service : 3. getUserConversations(userId)
activate Service

Service -> Model : 4. find(userId)
activate Model

Model -> Database : 5. Execute query
activate Database
Database --> Model : 6. Return result
deactivate Database

Model --> Service : 7. Return conversation list
deactivate Model

Service -> Service : 8. process conversation data
activate Service
space
deactivate Service
 
alt Conversations available
    Service --> Controller : 8.1 Return conversation list
    Controller --> View : 8.1.1 Show conversation UI
    View --> User : 8.1.2 Display conversations

else No conversations
    Service --> Controller : 8.2 Return empty list
    deactivate Service

    Controller --> View : 8.2.1 Show empty conversation UI
    deactivate Controller

    View --> User : 8.2.2 Display "No messages yet. Start the conversation!"

    deactivate View
    deactivate User
end