@startuml 15.4_deleteStep
hide footbox
title Delete Step

actor User as "Users"
boundary StepPage as View
participant ":StepRoute" as Route
control "AuthMiddleware" as Middleware
control "StepController" as Controller
participant ":StepService" as Service
entity "StepModel" as Model
database Database as Database

User -> View : 1. Click "Delete" on a step
activate View
activate User
View --> User : 2. Show confirmation dialog
User -> View : 3. Confirm delete

    View -> Route : 4. DELETE /steps/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 6. Forward DeleteStepRequest(stepId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process step deletion
    activate Service

alt Step not found
    Service -> Model : 8.1. Find step by ID
    activate Model

    Model -> Database : 8.1.1. Retrieve step data by ID
    activate Database
    Database --> Model : 8.1.2. Result (null)
    deactivate Database

    Model --> Service : 8.1.3. Return not found
    deactivate Model

        Service --> Controller : 8.1.4. Return not found result
        Controller --> Route : 8.1.5. Return 404 Not Found + message
        Route --> View : 8.1.6. Show error: "Step not found"
else Step exists
        Service -> Model : 8.2. Delete step by ID
        activate Model

        Model -> Database : 8.2.1. Persist deletion
        activate Database
        Database --> Model : 8.2.2. Delete success
        deactivate Database

        Model --> Service : 8.2.3. Return deletion result
        deactivate Model

        Service --> Controller : 8.2.4. Return DeleteStepResponse
        deactivate Service
        Controller --> Route : 8.2.5. Return 200 OK + success message
        deactivate Controller
        Route --> View : 8.2.6. Show delete success
        deactivate Route
end

View --> User : 9. Display result (success or error)
deactivate View
deactivate User
@enduml
