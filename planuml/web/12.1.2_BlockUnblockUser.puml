@startuml 12.1.2_BlockUnblockUser
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control userManagementRoute as Route
participant ":authMiddleware" as Middleware
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Enter block/unblock status
activate UI
User -> UI : 2. Click submit button
UI -> UI : 3. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 3.1 Display error message
end
UI -> Route : 4. PUT /userManagement/blockStatus/:userId
activate Route
Route -> Middleware : 5. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 6. handleBlockUnblockUser(userInfo, userId, status)
deactivate Middleware
activate Controller
Controller -> Controller : 7. validateInput()
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 7.1 Return error
    Route --> UI : 7.2 Show error message
    UI --> User : 7.3 Display error message
end
Controller -> Service : 8. blockUnblockUser(userId, status)
activate Service
Service -> Model : 9. findById(userId)
activate Model
Model -> DB : 10. execute query findOne
activate DB
DB --> Model : 11. Return user document
deactivate DB
Model --> Service : 12. Return user document
deactivate Model
Service -> Service : 13. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 13.1 Return error
    Controller --> Route : 13.2 Return error info
    Route --> UI : 13.3 Show error message
    UI --> User : 13.4 Display error message
end
Service -> Service : 14. checkNotFound()
activate Service
deactivate Service
opt user not found
    Service --> Controller : 14.1 Return error
    Controller --> Route : 14.2 Return error info
    Route --> UI : 14.3 Show error message
    UI --> User : 14.4 Display error message
end
Service -> Model : 15. updateBlockStatus(userId, status)
activate Model
Model -> DB : 16. execute query updateOne
activate DB
DB --> Model : 17. Return update result
deactivate DB
Model --> Service : 18. Return update result
deactivate Model
Service -> Service : 19. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 19.1 Return error
    Controller --> Route : 19.2 Return error info
    Route --> UI : 19.3 Show error message
    UI --> User : 19.4 Display error message
end
Service -> Service : 20. mapToUserDTO()
activate Service
deactivate Service
Service --> Controller : 21. Return success
deactivate Service
Controller --> Route : 22. Return success
deactivate Controller
Route --> UI : 23. Return success
deactivate Route

UI --> User : 24. Show updated user status
deactivate UI
deactivate User

@enduml
