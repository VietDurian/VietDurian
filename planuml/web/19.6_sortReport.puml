@startuml SortReport

actor Admin
boundary "ReportPage" as View 
participant ":reportPostRoute" as Route 
control ":authMiddleware" as Auth 
control "reportPostController" as Controller 
participant ":reportPostService" as Service 
entity "reportPostModel" as Model 
database "MongoDB" as MongoDB 
hide footbox

Admin -> View: 1. Select sort criteria (Date)
activate Admin
activate View

View -> Route: 2. GET /api/v1/report?sort=Date
activate Route

Route -> Auth: 3. authenticateUser(req, res, next)
activate Auth
ref over Admin, MongoDB : Verifies token

Auth -> Controller: 4. next(req)    
deactivate Auth
activate Controller

Controller -> Service: 5. handleGetProfile(userId)
activate Service

Service -> Model: 6. find().sort(criteria)
activate Model

Model -> MongoDB: 7. Query sorted reports
activate MongoDB

MongoDB --> Model: 8. Return sorted list
deactivate MongoDB

Model --> Service: 9. Return sorted list
deactivate Model

Service --> Controller: 10. Return sorted list
deactivate Service

Controller --> Route: 11. Return 200 OK + data
deactivate Controller

Route --> View: 12. Update report list
deactivate Route

View --> Admin: 13. Display sorted reports
deactivate View
deactivate Admin

@enduml