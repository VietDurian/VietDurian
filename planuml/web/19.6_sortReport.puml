@startuml SortReport

actor Admin
boundary "ReportPage" as View 
participant ":reportRoute" as Route 
control ":authMiddleware" as Auth 
control "reportController" as Controller 
participant ":reportService" as Service 
entity "reportModel" as Model 
database "MongoDB" as MongoDB 
hide footbox

Admin -> View: 1. Select sort criteria (Date)
activate Admin
activate View

View -> Route: 2. GET /api/v1/report?sort=Date
activate Route

Route -> Auth: 3. authenticateUser(req, res, next)
activate Auth
ref over Admin, MongoDB : Verifies token

Auth --> Route: 4. authentication success
deactivate Auth

Route -> Controller: 5. getAllReport(req, res)
activate Controller

Controller -> Service: 6. getAllReport(query)
activate Service

Service -> Model: 7. find().sort(criteria)
activate Model

Model -> MongoDB: 8. Query sorted reports
activate MongoDB

MongoDB --> Model: 9. Return sorted list
deactivate MongoDB

Model --> Service: 10. Return sorted list
deactivate Model

Service --> Controller: 11. Return sorted list
deactivate Service

Controller --> Route: 12. Return 200 OK + data
deactivate Controller

Route --> View: 13. Update report list
deactivate Route

View --> Admin: 14. Display sorted reports
deactivate View
deactivate Admin

@enduml