@startuml 9.7_viewCapabilityProfile
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Users
boundary CapabilityProfilePage as UI
control serviceProviderProfileController as Controller
participant ":serviceProviderProfileService" as Service
participant ":serviceProviderProfileModel" as Model
database Database as DB

activate Users
Users -> UI : 1. Click "View Capability Profile"
activate UI
UI -> Controller : 2. GET /service-provider-profile/capability
activate Controller
Controller -> Service : 3. getCapabilityProfile(userId)
activate Service
Service -> Model : 4. findByUserId(userId)
activate Model
Model -> DB : 5. findOne()
activate DB
DB --> Model : 6. Return profile document (or null)
deactivate DB
Model --> Service : 7. Return raw result
deactivate Model
Service -> Service : 8. checkQuerySuccess()
activate Service
deactivate Service
opt database error
    Service --> Controller : 8.1 Return error
    Controller --> UI : 8.2 Return error
    UI --> Users : 8.3 Display error message
else no database error
    Service -> Service : 9. checkNotFound()
    activate Service
    deactivate Service
    alt profile not found
        Service --> Controller : 9.1 Return error: profile not found
        Controller --> UI : 9.1.1 Return error
        UI --> Users : 9.1.2 Display error: profile not found
    else profile found
        Service -> Service : 9.2 filterServiceAreas()
        activate Service
        deactivate Service
        Service -> Service : 9.3 mapToCapabilityDTO()
        activate Service
        deactivate Service
        Service --> Controller : 9.4 Return success + capability data
        deactivate Service
        Controller --> UI : 9.5 Return success + capability data
        deactivate Controller
        UI -> UI : 9.6 Render capability profile
        activate UI
        deactivate UI
        UI --> Users : 9.7 Display capability + service areas
        deactivate UI
        deactivate Users
    end
end
@enduml