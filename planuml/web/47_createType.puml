@startuml 47_createType
hide footbox

actor User as "Admin" 
boundary TypeManagementPage as View
control "TypeController" as Controller
participant ":TypeService" as Service
entity "TypeModel" as Model
database Database as Database


User -> View : 1. Enter name, description & submit
activate View
activate User
View -> View : 2. Validate input
opt Invalid Input or fields left empty
    View --> User : 2.1. Display errors message
end

User -> View : 3. Click "Cancel" icon
View -> View : 4. Return to previous page
activate View
deactivate View
opt Cancel creation
    View --> User : 4.1 Return to previous page
end

View -> Controller : 5. createTypeProduct(typeData)
activate Controller

Controller -> Service : 6. createTypeProduct(typeData)
activate Service

alt Type exists
    Service -> Model : 6.1. Check conflicts
    activate Model

    Model -> Database : 6.1.1. Check existing type
    activate Database
    Database --> Model : 6.1.2. Conflict result
    deactivate Database

    Model --> Service : 6.1.3. Return conflict state
    deactivate Model

        Service --> Controller : 6.1.4. Return type already exists
        Controller --> View : 6.1.5. Show error
else Type is valid
        Service -> Model : 6.2. save(typeData)
        activate Model

        Model -> Database : 6.2.1. save new type
        activate Database
        Database --> Model : 6.2.2. Return result
        deactivate Database

        Model --> Service : 6.2.3. Return created entity
        deactivate Model

        Service --> Controller : 6.2.4. Return TypeResponse
        deactivate Service
        Controller --> View : 6.2.5. Show success
        deactivate Controller
end

View --> User : 7. Display form result (success or error)
deactivate View
deactivate User
@enduml
