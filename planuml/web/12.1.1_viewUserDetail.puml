@startuml 12.1.1_viewUserDetail
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control userManagementRoute as Route
participant ":authMiddleware" as Middleware
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Click on user to view details
activate UI
UI -> Route : 2. GET /userManagement/detail/:userId
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 4. handleGetUserDetail(userInfo, userId)
deactivate Middleware
activate Controller
Controller -> Service : 5. getUserDetail(userId)
activate Service
Service -> Model : 6. findById(userId)
activate Model
Model -> DB : 7. execute query findOne({_id: userId})
activate DB
DB --> Model : 8. Return user document
deactivate DB
Model --> Service : 9. Return user document
deactivate Model
Service -> Service : 10. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 10.1 Return error
    Controller --> Route : 10.2 Return error info
    Route --> UI : 10.3 Show error message
    UI --> User : 10.4 Display error message
end
Service -> Service : 11. checkNotFound()
activate Service
deactivate Service
opt user not found
    Service --> Controller : 11.1 Return error
    Controller --> Route : 11.2 Return error info
    Route --> UI : 11.3 Show error message
    UI --> User : 11.4 Display error message
end
Service -> Service : 12. mapToUserDetailDTO()
activate Service
deactivate Service
Service --> Controller : 13. Return success
deactivate Service
Controller --> Route : 14. Return success
deactivate Controller
Route --> UI : 15. Return success
deactivate Route

UI --> User : 16. Display user detailed information
deactivate UI
deactivate User

@enduml
