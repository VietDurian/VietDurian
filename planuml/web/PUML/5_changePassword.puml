@startuml 5_changePassword
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Users
boundary authChangePasswordPage as UI
control authController as Controller
participant ":authService" as AuthService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate Users
Users -> UI : 1. Open change password page
activate UI
UI --> Users : 2. Render change password form
Users -> UI : 3. Enter form (old password, new password, confirm)
Users -> UI : 4. Click change password button
UI -> UI : 5. Validate input
activate UI
deactivate UI
opt validation error
    UI --> Users : 5.1 Display validation error
end

UI -> Controller : 6. POST /auth/change-password
activate Controller
Controller -> Controller : 9. validateInput()
activate Controller
deactivate Controller
opt invalid input data
    Controller --> UI : 9.1 Return error
    UI --> Users : 9.2 Display error message
end

Controller -> AuthService : 10. handleChangePassword()
activate AuthService
AuthService -> UserService : 11. lookupUserById()
activate UserService
UserService -> UserModel : 12. findById()
activate UserModel
UserModel -> DB : 13. findOne()
activate DB
DB --> UserModel : 14. Return user document
deactivate DB
UserModel --> UserService : 15. Return user entity 
deactivate UserModel
UserService --> AuthService : 16. Return user entity 
deactivate UserService
AuthService -> AuthService : 17. validatePersistenceResult()
activate AuthService
deactivate AuthService
opt Persistence error
    AuthService --> Controller : 17.1 Return error
    Controller --> UI : 17.2 Return error
    UI --> Users : 17.3 Display error message
end
AuthService -> AuthService : 18. checkUserPresence()
activate AuthService
deactivate AuthService
opt user not found
    AuthService --> Controller : 18.1 Return error
    Controller --> UI : 18.2 Return error
    UI --> Users : 18.3 Display error message
end

AuthService -> AuthService : 19. verifyOldPassword()
activate AuthService
deactivate AuthService
opt old password incorrect
    AuthService --> Controller : 19.1 Return error
    Controller --> UI : 19.2 Return error
    UI --> Users : 19.3 Display error message
end

AuthService -> AuthService : 20. hashNewPassword()
activate AuthService
deactivate AuthService
AuthService -> UserService : 21. updatePassword()
activate UserService
UserService -> UserModel : 22. updateUserRecord()
activate UserModel
UserModel -> DB : 23. updateOne()
activate DB
DB --> UserModel : 24. Return modified count
deactivate DB
UserModel --> UserService : 25. Return result
deactivate UserModel
UserService -> UserService : 26. Validate persistence result
activate UserService
deactivate UserService
opt Persistence error
    UserService --> AuthService : 26.1 Return error
    AuthService --> Controller : 26.2 Return error
    Controller --> UI : 26.3 Return error
    UI --> Users : 26.4 Display error message
end
UserService --> AuthService : 27. Return success
deactivate UserService
AuthService --> Controller : 28. Return success
deactivate AuthService
Controller --> UI : 29. Return success
deactivate Controller
UI --> Users : 30. Display success message
deactivate UI
deactivate Users
@enduml
