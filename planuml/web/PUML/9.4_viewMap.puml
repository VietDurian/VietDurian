@startuml 9.4_viewMap
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary mapViewPage as UI
control profileRoute as Route
participant ":authMiddleware" as AuthMiddleware
control profileController as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Click open map
activate UI
UI -> Route : 2. GET /profile/map 
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token
AuthMiddleware -> Controller : 4. handleGetMap(userId)
deactivate AuthMiddleware
activate Controller
Controller -> ProfileService : 5. getMapData(userId)
activate ProfileService
ProfileService -> UserService : 6. getNurseryLocations(userId)
activate UserService
UserService -> UserModel : 7. find()
activate UserModel
UserModel -> DB : 8. execute query find
activate DB
DB --> UserModel : 9. Return nursery documents
deactivate DB
UserModel --> UserService : 10. Return nursery entities
deactivate UserModel
UserService -> UserService : 11. checkDatabaseError()
activate UserService
deactivate UserService
opt database error
    UserService --> ProfileService : 11.1 Return badrequest
    ProfileService --> Controller : 11.2 Return error response
    Controller --> Route : 11.3 Return error response
    Route --> UI : 11.4 Return error response
    UI --> User : 11.5 Display error message
end
UserService --> ProfileService : 12. Return nursery data
deactivate UserService
ProfileService -> ProfileService : 13. extractLocationData()
activate ProfileService
deactivate ProfileService
ProfileService -> ProfileService : 14. formatMapMarkers()
activate ProfileService
deactivate ProfileService
ProfileService -> ProfileService : 15. mapToMapDTO()
activate ProfileService
deactivate ProfileService
ProfileService --> Controller : 16. Return success + map data
deactivate ProfileService
Controller --> Route : 17. Return success + map data 
deactivate Controller
Route --> UI : 18. Return success + map data 
deactivate Route

UI --> User : 19. Display map with markers
deactivate UI
deactivate User

@enduml
