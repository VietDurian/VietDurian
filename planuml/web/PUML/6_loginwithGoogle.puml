@startuml
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary loginScreen as UI
control authenticationController as Controller
participant ":authenticationService" as Service
participant ":googleService" as GoogleSvc
participant ":userModel" as Model
participant ":authService" as AuthSvc
participant LocalStorage as LS
participant "Google OAuth" as Google
database Database as DB

activate User
User -> UI : 1. Open login page
activate UI
User -> UI : 2. Click "Login with Google" button

UI -> Controller : 3. getGoogleAuthUrl()
activate Controller
Controller -> GoogleSvc : 4. generateAuthUrl()
activate GoogleSvc
GoogleSvc --> Controller : 5. return googleAuthUrl
deactivate GoogleSvc
Controller --> UI : 6. return googleAuthUrl
deactivate Controller

UI -> Google : 7. Open Google OAuth URL
activate Google
Google --> User : 8. Show Google login page

opt User cancels or closes Google login
    User -> Google : 8.1 Cancel/Close login
    Google --> UI : 8.2 Login cancelled
    UI --> User : 8.3 Display "Login cancelled by user"
end

User -> Google : 9. Enter Google credentials and authorize
Google -> Google : 10. Validate credentials
activate Google
deactivate Google

opt Google authentication failed
    Google --> UI : 10.1 Authentication error
    UI --> User : 10.2 Display "Google authentication failed"
end

Google --> UI : 11. Return authorization code
deactivate Google

UI -> Controller : 12. verifyGoogleAuth(authCode)
activate Controller
Controller -> GoogleSvc : 13. verifyAuthCode(authCode)
activate GoogleSvc
GoogleSvc -> Google : 14. Exchange code for user info
activate Google
Google --> GoogleSvc : 15. Return user info (email, name, etc.)
deactivate Google

GoogleSvc -> GoogleSvc : 16. validateGoogleResponse()
activate GoogleSvc
deactivate GoogleSvc
opt Google verification failed
    GoogleSvc --> Controller : 16.1 throw Error('Google verification failed')
    Controller --> UI : 16.2 throw Error('Google verification failed')
    UI --> User : 16.3 Display error message
end

GoogleSvc --> Controller : 17. return googleUserInfo
deactivate GoogleSvc

Controller -> Service : 18. authenticateWithGoogle(googleUserInfo)
activate Service
Service -> Model : 19. findByEmail(email)
activate Model
Model -> DB : 20. findOne({email: email})
activate DB
DB --> Model : 21. Return user document (or null)
deactivate DB
Model --> Service : 22. Return user entity (or null)
deactivate Model

Service -> Service : 23. checkUserExists()
activate Service
deactivate Service
alt user not found
    Service -> Model : 23.1 createNewUser(googleUserInfo)
    activate Model
    Model -> DB : 23.2 insertOne({email, name, ...})
    activate DB
    DB --> Model : 23.3 Return inserted user document
    deactivate DB
    Model --> Service : 23.4 Return new user entity
    deactivate Model
else user exists
    Service -> Service : 23.5 Continue with existing user
    activate Service
    deactivate Service
end

Service -> Service : 24. checkUserStatus()
activate Service
deactivate Service
opt user is banned
    Service --> Controller : 24.1 throw Error('Account has been banned')
    Controller --> UI : 24.2 throw Error('Account has been banned')
    UI --> User : 24.3 Display error message
end

opt user is deleted
    Service --> Controller : 24.4 throw Error('Account has been deleted')
    Controller --> UI : 24.5 throw Error('Account has been deleted')
    UI --> User : 24.6 Display error message
end

Service -> AuthSvc : 25. generateToken(userData)
activate AuthSvc
AuthSvc --> Service : 26. Return JWT token
deactivate AuthSvc

Service --> Controller : 27. return {token, userData}
deactivate Service

Controller --> UI : 28. return {token, userData}
deactivate Controller

UI -> LS : 29. setItem("token", token)
activate LS
LS --> UI : 30. Token stored successfully
deactivate LS

UI -> LS : 31. setItem("userData", userData)
activate LS
LS --> UI : 32. User data stored successfully
deactivate LS

UI --> User : 33. Login successful, redirect to dashboard
deactivate UI
deactivate User

@enduml