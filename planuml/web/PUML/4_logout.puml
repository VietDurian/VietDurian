@startuml 4_logout
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Users
boundary authLogoutPage as UI
boundary localStorage as Storage
control authController as Controller
participant ":authService" as AuthService
participant ":blacklistModel" as BlacklistModel
database Database as DB

activate Users
Users -> UI : 1. Click logout button
activate UI
UI -> Controller : 2. POST /auth/logout
activate Controller
Controller -> Controller : 3. Process logout request
Controller -> AuthService : 4. handleLogout()
activate AuthService
AuthService -> BlacklistModel : 5. addToBlacklist()
activate BlacklistModel
BlacklistModel -> DB : 6. insertOne()
activate DB
DB --> BlacklistModel : 7. Return inserted document
deactivate DB
BlacklistModel --> AuthService : 8. Return result
deactivate BlacklistModel
AuthService -> AuthService : 9. validatePersistenceResult()
activate AuthService
deactivate AuthService
opt Persistence error
    AuthService --> Controller : 9.1 Return error
    Controller --> UI : 9.2 Return error
    UI --> Users : 9.4 Display error message
end
AuthService --> Controller : 10. Return success
deactivate AuthService
Controller --> UI : 11. Return success
deactivate Controller
UI -> Storage : 12. Clear local storage
activate Storage

Storage --> UI : 13. Confirm cleared
deactivate Storage
UI --> Users : 14. Redirect to login page
deactivate UI
deactivate Users
@enduml
