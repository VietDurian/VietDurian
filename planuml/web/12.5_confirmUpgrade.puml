@startuml 12.5_confirmUpgrade
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control userManagementRoute as Route
participant ":authMiddleware" as Middleware
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Review upgrade request
activate UI
User -> UI : 2. Select approval or rejection decision
User -> UI : 3. Click confirm button
UI -> UI : 4. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 4.1 Display error message
end
UI -> Route : 5. PUT /userManagement/confirmUpgrade/:userId
activate Route
Route -> Middleware : 6. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 7. handleConfirmUpgrade(userInfo, userId, decision)
deactivate Middleware
activate Controller
Controller -> Controller : 8. validateInput()
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 8.1 Return error
    Route --> UI : 8.2 Show error message
    UI --> User : 8.3 Display error message
end
Controller -> Service : 9. confirmUpgrade(userId, decision)
activate Service
Service -> Model : 10. findById(userId)
activate Model
Model -> DB : 11. execute query findOne
activate DB
DB --> Model : 12. Return user document
deactivate DB
Model --> Service : 13. Return user document
deactivate Model
Service -> Service : 14. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 14.1 Return error
    Controller --> Route : 14.2 Return error info
    Route --> UI : 14.3 Show error message
    UI --> User : 14.4 Display error message
end
Service -> Service : 15. checkNotFound()
activate Service
deactivate Service
opt user not found
    Service --> Controller : 15.1 Return error
    Controller --> Route : 15.2 Return error info
    Route --> UI : 15.3 Show error message
    UI --> User : 15.4 Display error message
end
Service -> Model : 16. updateAccountLevel(userId, decision)
activate Model
Model -> DB : 17. execute query updateOne
activate DB
DB --> Model : 18. Return update result
deactivate DB
Model --> Service : 19. Return update result
deactivate Model
Service -> Service : 20. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 20.1 Return error
    Controller --> Route : 20.2 Return error info
    Route --> UI : 20.3 Show error message
    UI --> User : 20.4 Display error message
end
Service -> Service : 21. mapToUserDTO()
activate Service
deactivate Service
Service --> Controller : 22. Return success
deactivate Service
Controller --> Route : 23. Return success
deactivate Controller
Route --> UI : 24. Return success
deactivate Route

UI --> User : 25. Show updated account level
deactivate UI
deactivate User

@enduml
