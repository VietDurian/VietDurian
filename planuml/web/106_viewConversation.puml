@startuml 111_sendMessage
hide footbox

actor User as "Users" 
boundary ChatPage as View
control "MessageController" as Controller
participant ":MessageService" as Service
entity "MessageModel" as Model
database Database as Database


User -> View : 1. Click "Chat" icon on the product details page or navbar.
activate View
activate User

View -> Controller : 2. Get conversation request
activate Controller

Controller -> Service : 3. getUsersForSidebar(userId)
activate Service

Service -> Model : 4. find(userId)
activate Model

Model -> Database : 5. Execute query
activate Database
Database --> Model : 6. Return result
deactivate Database

Model --> Service : 7. Return created entity
deactivate Model

Service -> Service : 8. Process data for sidebar
activate Service
deactivate Service

opt Empty conversation
    Service --> Controller : 8.1. Return success

    Controller --> View : 8.1.1. Show empty conversation UI

    View --> User : 8.1.2. Display 'No messages yet. Start the conversation!'
end

Service --> Controller : 9. Return success
deactivate Service

Controller --> View : 10. Show conversation UI
deactivate Controller

View --> User : 11. Display conversation with messages
deactivate View
 deactivate User
@enduml
