@startuml 9.5_registerGardenRecord
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary gardenRecordPage as UI
control gardenRoute as Route
participant ":authMiddleware" as Middleware
control gardenController as Controller
participant ":gardenService" as Service
participant ":gardenModel" as Model
database Database as DB

activate User
User -> UI : 1. Open garden record form
activate UI
User -> UI : 2. Enter garden record details
User -> UI : 3. Click submit button
UI -> UI : 4. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 4.1 Display error message
end
UI -> Route : 5. POST /garden/record
activate Route
Route -> Middleware : 6. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware --> Route : 7. User authenticated & authorized
deactivate Middleware
Route -> Controller : 8. handleRegisterGardenRecord(userInfo)
activate Controller
Controller -> Controller : 9. Validate input
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 9.1 Return error
    Route --> UI : 9.2 Show error message
    UI --> User : 9.3 Display error message
end
Controller -> Service : 10. registerGardenRecord(data)
activate Service
Service -> Model : 11. findByName(gardenName)
activate Model
Model -> DB : 12. findOne({name: 'gardenName'})
activate DB
DB --> Model : 13. Return result
deactivate DB
Model --> Service : 14. Return garden entity
deactivate Model
Service -> Service : 15. checkExists()
activate Service
deactivate Service
opt garden record already exists
    Service --> Controller : 15.1 Return error
    Controller --> Route : 15.2 Return error info
    Route --> UI : 15.3 Show error message
    UI --> User : 15.4 Display error message
end
Service -> Model : 16. create(gardenData)
activate Model
Model -> DB : 17. insertOne({...})
activate DB
DB --> Model : 18. Return result
deactivate DB
Model --> Service : 19. Return insert result
deactivate Model
Service -> Service : 20. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 20.1 Return error
    Controller --> Route : 20.2 Return error info
    Route --> UI : 20.3 Show error message
    UI --> User : 20.4 Display error message
end
Service -> Service : 21. mapToGardenDTO()
activate Service
deactivate Service
Service --> Controller : 22. Return success
deactivate Service
Controller --> Route : 23. Return success
deactivate Controller
Route --> UI : 24. Return success
deactivate Route
UI --> User : 25. Display garden record created
deactivate UI
deactivate User

@enduml
