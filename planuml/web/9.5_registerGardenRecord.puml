@startuml 9.5_registerGardenRecord
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary gardenRecordPage as UI
control gardenRoute as Route
participant ":authMiddleware" as Middleware
control gardenController as Controller
participant ":gardenService" as Service
participant ":gardenModel" as Model
database Database as DB

activate User
User -> UI : 1. Open garden record form
activate UI
User -> UI : 2. Enter garden record details
User -> UI : 3. Click submit button
UI -> UI : 4. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 4.1 Display error message
end
UI -> Route : 5. POST /garden/record
activate Route
Route -> Middleware : 6. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 7. handleRegisterGardenRecord(userInfo)
deactivate Middleware
activate Controller
Controller -> Controller : 8. Validate input
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 8.1 Return error
    Route --> UI : 8.2 Show error message
    UI --> User : 8.3 Display error message
end
Controller -> Service : 9. registerGardenRecord(data)
activate Service
Service -> Model : 10. findByName(gardenName)
activate Model
Model -> DB : 11. execute query findOne
activate DB
DB --> Model : 12. Return result
deactivate DB
Model --> Service : 13. Return garden entity
deactivate Model
Service -> Service : 14. checkExists()
activate Service
deactivate Service
opt garden record already exists
    Service --> Controller : 14.1 Return error
    Controller --> Route : 14.2 Return error info
    Route --> UI : 14.3 Show error message
    UI --> User : 14.4 Display error message
end
Service -> Model : 15. create(gardenData)
activate Model
Model -> DB : 16. execute query insertOne
activate DB
DB --> Model : 17. Return result
deactivate DB
Model --> Service : 18. Return insert result
deactivate Model
Service -> Service : 19. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 19.1 Return error
    Controller --> Route : 19.2 Return error info
    Route --> UI : 19.3 Show error message
    UI --> User : 19.4 Display error message
end
Service -> Service : 20. mapToGardenDTO()
activate Service
deactivate Service
Service --> Controller : 21. Return success
deactivate Service
Controller --> Route : 22. Return success
deactivate Controller
Route --> UI : 23. Return success
deactivate Route
UI --> User : 24. Display garden record created
deactivate UI
deactivate User

@enduml
