@startuml 13.7_sortProduct
hide footbox
title Sort Product

actor User
boundary ProductPage as View
control ProductRoute as Route
participant ":AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
participant ":ProductModel" as Model
database Database as Database

User -> View : 1. Choose sort option
activate View

    View -> Route : 2. GET /products?sort=&page=&size=
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 4. Authentication success
    Middleware -> Controller : 5. Forward SortProductRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 6. Process product sorting
    activate Service

    Service -> Model : 7. Build sort criteri
    activate Model

    Model -> Database : 8. Retrieve products ordered by criteria
    activate Database
    Database --> Model : 9. Result set
    deactivate Database

    Model --> Service : 10. Return sorted list + paging info
    deactivate Model

alt No products available
    Service --> Controller : 11.1. Return empty result
    Controller --> Route : 11.1.1. Return 200 OK + empty list/message
    Route --> View : 11.1.2. Show "No products available"
else Products available
    Service --> Controller : 11.2. Return SortProductResponse
    deactivate Service
    Controller --> Route : 11.2.1. Return 200 OK + sorted products data
    deactivate Controller
    Route --> View : 11.2.2. Render sorted list + keep sort option selected
    deactivate Route
end

View --> User : 12. Display sorted result
deactivate View
@enduml
