@startuml 13.7_sortProduct
hide footbox
title Sort Product

actor User as "Users"
boundary ProductPage as View
participant ":ProductRoute" as Route
control "AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Choose sort option
activate View
activate User

    View -> Route : 2. GET /products?sort=&page=&size=
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 4. Forward SortProductRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 5. Process product sorting
    activate Service

    Service -> Model : 6. Build sort criteria
    activate Model

    Model -> Database : 7. Retrieve products ordered by criteria
    activate Database
    Database --> Model : 8. Result set
    deactivate Database

    Model --> Service : 9. Return sorted list + paging info
    deactivate Model

alt No products available
    Service --> Controller : 10.1. Return empty result
    Controller --> Route : 10.1.1. Return 200 OK + empty list/message
    Route --> View : 10.1.2. Show "No products available"
else Products available
    Service --> Controller : 10.2. Return SortProductResponse
    deactivate Service
    Controller --> Route : 10.2.1. Return 200 OK + sorted products data
    deactivate Controller
    Route --> View : 10.2.2. Render sorted list + keep sort option selected
    deactivate Route
end

View --> User : 11. Display sorted result
deactivate View
deactivate User
@enduml
