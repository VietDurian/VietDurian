@startuml 14.5_filterType
hide footbox
title Filter Type

actor User as "Users"
boundary TypePage as View
participant ":TypeRoute" as Route
control "AuthMiddleware" as Middleware
control "TypeController" as Controller
participant ":TypeService" as Service
entity "TypeModel" as Model
database Database as Database

User -> View : 1. Select filter options\n(keyword, status)
activate View
activate User

    View -> Route : 3. GET /types/filter?keyword=&status=
    activate Route

    Route -> Middleware : 4. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 5. Forward FilterTypeRequest(params)
    deactivate Middleware
    activate Controller

    Controller -> Service : 6. Process type filtering
    activate Service

    Service -> Model : 7. Build filter criteria
    activate Model

    Model -> Database : 8. Retrieve filtered type data
    activate Database
    Database --> Model : 9. Result set
    deactivate Database

    Model --> Service : 10. Return filtered list + paging info
    deactivate Model

alt No types match
    Service --> Controller : 11.1. Return empty result
    Controller --> Route : 11.1.1 Return 200 OK + empty list/message
    Route --> View : 11.1.2. Show "No types found" + keep filters
else Types match
    Service --> Controller : 11.2. Return FilterTypeResponse
    deactivate Service
    Controller --> Route : 11.2.1. Return 200 OK + filtered types data
    deactivate Controller
    Route --> View : 11.2.2. Render filtered list + pagination
    deactivate Route
end

View --> User : 12. Display filter result
deactivate View
deactivate User
@enduml
