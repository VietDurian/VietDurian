@startuml SearchReportByDish

actor Admin
boundary "ReportPage" as View 
participant ":reportRoute" as Route 
control ":authMiddleware" as Auth 
control "reportController" as Controller 
participant ":reportService" as Service 
entity "reportModel" as Model 
database "MongoDB" as MongoDB
hide footbox

Admin -> View: 1. Enter blog title and click "Search"
activate Admin
activate View

View -> Route: 2. GET /api/v1/report/search?blogTitle={keyword}
activate Route

Route -> Auth: 3. authenticateUser(req, res, next)
activate Auth
ref over Admin, MongoDB : Verifies token

Auth -> Controller: 4. next(req)
deactivate Auth
activate Controller

Controller -> Service: 5. getAllReports(keyword)
activate Service

Service -> Service: 6. check keyword
activate Service
deactivate Service

alt Empty search field
    Service -> Model: 6.1. find(keyword)
    activate Model
    Model -> MongoDB: 6.1.1. Query all reports
    activate MongoDB
    MongoDB --> Model: 6.1.2. Return all reports
    deactivate MongoDB
    Model --> Service: 6.1.3. Return reports
    deactivate Model
else Keyword entered
    Service -> Model: 6.2. find(keyword)
    activate Model
    Model -> MongoDB: 6.2.1. Query reports by blogTitle
    activate MongoDB
    MongoDB --> Model: 6.2.2. Return matching reports
    deactivate MongoDB
    Model --> Service: 6.2.3. Return results
    deactivate Model
end

Service -> Service: 7. check search results
activate Service
deactivate Service

alt No matching reports
    Service --> Controller: 7.1. Return empty result
    Controller --> Route: 7.1.1 Return success
    Route --> View: 7.1.2 Display empty result 
    View --> Admin: 7.1.3 Show "No reports found for this blog title"
else Reports found
    Service --> Controller: 7.2. Return reports
    deactivate Service
    Controller --> Route: 7.2.1 Return success 
    deactivate Controller
    Route --> View: 7.2.2 Render report list
    deactivate Route
    View --> Admin: 7.2.3 Show reports list
    deactivate View
    deactivate Admin
end
@enduml
