@startuml 9.1_viewProfile
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User as "Users"
boundary "ProfileViewPage" as UI
participant ":profileRoute" as Route
control ":authMiddleware" as AuthMiddleware
control "profileController" as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
entity ":userModel" as UserModel
database "MongoDB" as DB

activate User
User -> UI : 1. Click view profile
activate UI
UI -> Route : 2. GET /profile/me
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req, res, next)
activate AuthMiddleware
ref over User, DB: Verifies token
AuthMiddleware --> Route : 4. authentication success
deactivate AuthMiddleware
Route -> Controller : 5. handleGetProfile(userId)
activate Controller
Controller -> ProfileService : 6. getProfile(userId)
activate ProfileService
ProfileService -> UserService : 7. findById(userId)
activate UserService
UserService -> UserModel : 8. findOne()
activate UserModel
UserModel -> DB : 9. findOne()
activate DB
DB --> UserModel : 10. Return user document | null 
deactivate DB
UserModel --> UserService : 11. Return raw result
deactivate UserModel
UserService -> UserService : 12. checkNotFound()
activate UserService
deactivate UserService
alt user not found (null document)
    UserService --> ProfileService : 13.1 Return notfound
    ProfileService --> Controller : 13.1.1 Return error response
    Controller --> Route : 13.1.2 Return error response
    Route --> UI : 13.1.3 Return error response
    UI -> User : 13.1.4 Display user not found
else
    UserService --> ProfileService : 13.2 Return user entity
    deactivate UserService
    ProfileService --> Controller : 13.2.1 Return success + user data
    deactivate ProfileService
    Controller --> Route : 13.2.2 Return success + user data 
    deactivate Controller
    Route --> UI : 13.2.3 Return success + user data 
    deactivate Route
    UI --> User : 13.2.4 Display profile
    deactivate UI
    deactivate User
end
@enduml
