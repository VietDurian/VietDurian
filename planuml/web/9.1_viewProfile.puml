@startuml 9.1_viewProfile
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox


actor User as "Users"
boundary "ProfileViewPage" as UI
participant ":profileRoute" as Route
control ":authMiddleware" as AuthMiddleware
control "profileController" as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
entity ":userModel" as UserModel
database "MongoDB" as DB

activate User
User -> UI : 1. Click view profile
activate UI
UI -> Route : 2. GET /profile/me
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req, res, next)
activate AuthMiddleware

ref over User, DB: Verifies token
AuthMiddleware -> Controller : 4. handleGetProfile(userId)
deactivate AuthMiddleware
activate Controller
Controller -> ProfileService : 5. getProfile(userId)
activate ProfileService
ProfileService -> UserService : 6. findById(userId)
activate UserService
UserService -> UserModel : 7. findOne()
activate UserModel
UserModel -> DB : 8. execute query findOne
activate DB
DB --> UserModel : 9. Return user document
deactivate DB
UserModel --> UserService : 10. Return raw result
deactivate UserModel
UserService -> UserService : 11. checkQuerySuccess()
activate UserService
deactivate UserService
opt database error
    UserService --> ProfileService : 11.1 Return badrequest
    ProfileService --> Controller : 11.2 Return error response
    Controller --> Route : 11.3 Return error response
    Route --> UI : 11.4 Return error response
    UI -> User : 11.5 Display error message
end
UserService -> UserService : 12. checkNotFound()
activate UserService
deactivate UserService
opt user not found (null document)
    UserService --> ProfileService : 12.1 Return notfound
    ProfileService --> Controller : 12.2 Return error response
    Controller --> Route : 12.3 Return error response
    Route --> UI : 12.4 Return error response
    UI -> User : 12.5 Display user not found
end
UserService --> ProfileService : 13. Return user entity
deactivate UserService
ProfileService --> Controller : 14. Return success + user data
deactivate ProfileService
Controller --> Route : 15. Return success + user data 
deactivate Controller
Route --> UI : 16. Return success + user data 
deactivate Route
UI --> User : 17. Display profile
deactivate UI
deactivate User

@enduml
