@startuml 14.2_viewTypeList
hide footbox
title View Type List

actor User as "Users"
boundary TypePage as View
participant ":TypeRoute" as Route
control "AuthMiddleware" as Middleware
control "TypeController" as Controller
participant ":TypeService" as Service
entity "TypeModel" as Model
database Database as Database

User -> View : 1. Open type list page
activate View
activate User
    View -> Route : 2. GET /types
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 4. Forward ViewTypeListRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 5. Process type list retrieval
    activate Service

alt Types not found / empty
    Service -> Model : 6.1. Fetch types
    activate Model

    Model -> Database : 6.1.1. Retrieve types
    activate Database
    Database --> Model : 6.1.2. Result set (empty)
    deactivate Database

    Model --> Service : 6.1.3. Return list (empty)
    deactivate Model

        Service --> Controller : 6.1.4. Return empty result
        Controller --> Route : 6.1.5. Return 200 OK + empty list/message
        Route --> View : 6.1.6. Show "No types available"
else Types found
        Service -> Model : 6.2. Fetch types
        activate Model

        Model -> Database : 6.2.1. Retrieve types
        activate Database
        Database --> Model : 6.2.2. Result set (list)
        deactivate Database

        Model --> Service : 6.2.3. Return type list
        deactivate Model

        Service --> Controller : 6.2.4. Return TypeListResponse
        deactivate Service
        Controller --> Route : 6.2.5. Return 200 OK + types data
        deactivate Controller
        Route --> View : 6.2.6. Render type list
        deactivate Route
end

View --> User : 7. Display page content (list or empty state)
deactivate View
deactivate User
@enduml
