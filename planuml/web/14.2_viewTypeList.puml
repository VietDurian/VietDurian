@startuml 14.2_viewTypeList
hide footbox
title View Type List

actor User
boundary TypePage as View
control TypeRoute as Route
participant ":AuthMiddleware" as Middleware
control "TypeController" as Controller
participant ":TypeService" as Service
participant ":TypeModel" as Model
database Database as Database

User -> View : 1. Open type list page
activate View

    View -> Route : 2. GET /types
    activate Route

    Route -> Middleware : 4. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 5. Authentication success
    Middleware -> Controller : 6. Forward ViewTypeListRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process type list retrieval
    activate Service

alt Types not found / empty
    Service -> Model : 8.1. Fetch types
    activate Model

    Model -> Database : 8.1.1. Retrieve types
    activate Database
    Database --> Model : 8.1.2. Result set (empty)
    deactivate Database

    Model --> Service : 8.1.3. Return list (empty)
    deactivate Model

        Service --> Controller : 8.1.4. Return empty result
        Controller --> Route : 8.1.5. Return 200 OK + empty list/message
        Route --> View : 8.1.6. Show "No types available"
else Types found
        Service -> Model : 8.2. Fetch types
        activate Model

        Model -> Database : 8.2.1. Retrieve types
        activate Database
        Database --> Model : 8.2.2. Result set (list)
        deactivate Database

        Model --> Service : 8.2.3. Return type list
        deactivate Model

        Service --> Controller : 8.2.4. Return TypeListResponse
        deactivate Service
        Controller --> Route : 8.2.5. Return 200 OK + types data
        deactivate Controller
        Route --> View : 8.2.6. Render type list
        deactivate Route
end

View --> User : 9. Display page content (list or empty state)
deactivate View
@enduml
