@startuml 15.3_updateStep
hide footbox
title Update Step

actor User as "Users"
boundary EditStepPage as View
participant ":StepRoute" as Route
control "AuthMiddleware" as Middleware
control "StepController" as Controller
participant ":StepService" as Service
entity "StepModel" as Model
database Database as Database

User -> View : 1. Open step edit form
activate View
activate User

User -> View : 2. Edit step fields and submit
View -> View : 3. Validate form input

opt Check validation
    View --> User : 3.1. Show validation error
end

    View -> Route : 4. PUT /steps/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 6. Forward UpdateStepRequest(id, payload)
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process step update
    activate Service

alt Step not found
    Service -> Model : 8.1. Find step by ID
    activate Model

    Model -> Database : 8.1.1. Retrieve step data by ID
    activate Database
    Database --> Model : 8.1.2. Result (null)
    deactivate Database

    Model --> Service : 8.1.3. Return not found
    deactivate Model

        Service --> Controller : 8.1.4. Return not found result
        Controller --> Route : 8.1.5. Return 404 Not Found + message
        Route --> View : 8.1.6. Show error: "Step not found"
else Step exists
        Service -> Model : 8.2. Update step fields
        activate Model

        Model -> Database : 8.2.1. Persist updated step data
        activate Database
        Database --> Model : 8.2.2. Update success
        deactivate Database

        Model --> Service : 8.2.3. Return updated entity
        deactivate Model

        Service --> Controller : 8.2.4. Return UpdateStepResponse
        deactivate Service
        Controller --> Route : 8.2.5. Return 200 OK + updated step data
        deactivate Controller
        Route --> View : 8.2.6. Show success message
        deactivate Route
end

View --> User : 9. Display result (success or error)
deactivate View
deactivate User
@enduml
