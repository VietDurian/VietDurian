@startuml 10.1_createDiary
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary diaryPage as UI
control diaryRoute as Route
participant ":authMiddleware" as Middleware
control diaryController as Controller
participant ":diaryService" as Service
participant ":diaryModel" as Model
database Database as DB

activate User
User -> UI : 1. Open diary create form
activate UI
User -> UI : 2. Enter diary entry details
User -> UI : 3. Click submit button
UI -> UI : 4. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 4.1 Display error message
end
UI -> Route : 5. POST /diary/entry 
activate Route
Route -> Middleware : 6. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 7. handleCreateDiary(userInfo)
deactivate Middleware
activate Controller
Controller -> Controller : 8. Validate input
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 8.1 Return error
    Route --> UI : 8.2 Show error message
    UI --> User : 8.3 Display error message
end
Controller -> Service : 9. createDiary(data, userId)
activate Service
Service -> Model : 10. create(diaryData)
activate Model
Model -> DB : 11. execute query insertOne
activate DB
DB --> Model : 12. Return result
deactivate DB
Model --> Service : 13. Return insert result
deactivate Model
Service -> Service : 14. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 14.1 Return error
    Controller --> Route : 14.2 Return error info
    Route --> UI : 14.3 Show error message
    UI --> User : 14.4 Display error message
end
Service -> Service : 15. mapToDiaryDTO()
activate Service
deactivate Service
Service --> Controller : 16. Return success
deactivate Service
Controller --> Route : 17. Return success
deactivate Controller
Route --> UI : 18. Return success
deactivate Route

UI --> User : 19. Display diary entry created
deactivate UI
deactivate User

@enduml
