@startuml 13.5_filterProduct
hide footbox

actor User as "Users"
boundary ProductPage as View
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Select filter options\n(keyword, category, price)
activate View
activate User

    View -> Controller : 2. GET /products/filter?keyword=&categoryId=&price=
    activate Controller

    Controller -> Service : 5. filterProducts(params)
    activate Service

    Service -> Model : 6. Build filter criteria
    activate Model

    Model -> Database : 7. Retrieve filtered product data
    activate Database
    Database --> Model : 8. Result set
    deactivate Database

    Model --> Service : 9. Return filtered list + paging info
    deactivate Model

alt No products match
    Service --> Controller : 10.1. Return empty result
    Controller --> View : 10.1.1. Return 200 OK + empty list/message
    View --> User : 10.1.2. Show "No products found" + keep filters
else Products match
    Service --> Controller : 10.2. Return FilterProductResponse
    deactivate Service
    Controller --> View : 10.2.1. Return 200 OK + filtered products data
    deactivate Controller
    View -> View : 10.2.2. Render filtered list + pagination
end

View --> User : 11. Display filter result
deactivate View
deactivate User
@enduml
