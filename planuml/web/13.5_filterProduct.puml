@startuml 13.5_filterProduct
hide footbox
title Filter Product

actor User as "Users"
boundary ProductPage as View
participant ":ProductRoute" as Route
control "AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Select filter options\n(keyword, category, price)
activate View
activate User

    View -> Route : 2. GET /products/filter?keyword=&categoryId=&price=
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 4. Forward FilterProductRequest(params)
    deactivate Middleware
    activate Controller

    Controller -> Service : 5. Process product filtering
    activate Service

    Service -> Model : 6. Build filter criteria
    activate Model

    Model -> Database : 7. Retrieve filtered product data
    activate Database
    Database --> Model : 8. Result set
    deactivate Database

    Model --> Service : 9. Return filtered list + paging info
    deactivate Model

alt No products match
    Service --> Controller : 10.1. Return empty result
    Controller --> Route : 10.1.1. Return 200 OK + empty list/message
    Route --> View : 10.1.2. Show "No products found" + keep filters
else Products match
    Service --> Controller : 10.2. Return FilterProductResponse
    deactivate Service
    Controller --> Route : 10.2.1. Return 200 OK + filtered products data
    deactivate Controller
    Route --> View : 10.2.2. Render filtered list + pagination
    deactivate Route
end

View --> User : 11. Display filter result
deactivate View
deactivate User
@enduml
