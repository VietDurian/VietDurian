@startuml 16.2_viewCommentBlog
hide footbox
title View Comment Blog

actor User as "Users"
boundary CommentBlogPage as View
participant ":CommentBlogRoute" as Route
control "AuthMiddleware" as Middleware
control "CommentBlogController" as Controller
participant ":CommentBlogService" as Service
entity "CommentBlogModel" as Model
database Database as Database

User -> View : 1. Open comment page
activate View
activate User

    View -> Route : 2. GET /blogs/{blogId}/comments/{commentId}
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 4. Forward ViewCommentBlogRequest(commentId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 5. Process comment retrieval
    activate Service

alt Comment not found
    Service -> Model : 6.1. Find comment by ID
    activate Model

    Model -> Database : 6.1.1. Retrieve comment data by ID
    activate Database
    Database --> Model : 6.1.2. Result (null)
    deactivate Database

    Model --> Service : 6.1.3. Return not found
    deactivate Model

        Service --> Controller : 6.1.4. Return not found result
        Controller --> Route : 6.1.5. Return 404 Not Found + message
        Route --> View : 6.1.6. Show "Comment not found"
else Comment found
        Service -> Model : 6.2. Find comment by ID
        activate Model

        Model -> Database : 6.2.1. Retrieve comment data by ID
        activate Database
        Database --> Model : 6.2.2. Comment data
        deactivate Database

        Model --> Service : 6.2.3. Return comment entity
        deactivate Model

        Service --> Controller : 6.2.4. Return CommentBlogResponse
        deactivate Service
        Controller --> Route : 6.2.5. Return 200 OK + comment data
        deactivate Controller
        Route --> View : 6.2.6. Render comment detail
        deactivate Route
end

View --> User : 7. Display comment page content
deactivate View
deactivate User
@enduml
