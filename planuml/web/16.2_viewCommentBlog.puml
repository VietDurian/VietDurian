@startuml 16.2_viewCommentBlog
hide footbox
title View Comment Blog

actor User
boundary CommentBlogPage as View
control CommentBlogRoute as Route
participant ":AuthMiddleware" as Middleware
control "CommentBlogController" as Controller
participant ":CommentBlogService" as Service
participant ":CommentBlogModel" as Model
database Database as Database

User -> View : 1. Open comment page
activate View

    View -> Route : 2. GET /blogs/{blogId}/comments/{commentId}
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 4. Authentication success
    Middleware -> Controller : 5. Forward ViewCommentBlogRequest(commentId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 6. Process comment retrieval
    activate Service

alt Comment not found
    Service -> Model : 7.1. Find comment by ID
    activate Model

    Model -> Database : 7.1.1. Retrieve comment data by ID
    activate Database
    Database --> Model : 7.1.2. Result (null)
    deactivate Database

    Model --> Service : 7.1.3. Return not found
    deactivate Model

        Service --> Controller : 7.1.4. Return not found result
        Controller --> Route : 7.1.5. Return 404 Not Found + message
        Route --> View : 7.1.6. Show "Comment not found"
else Comment found
        Service -> Model : 7.2. Find comment by ID
        activate Model

        Model -> Database : 7.2.1. Retrieve comment data by ID
        activate Database
        Database --> Model : 7.2.2. Comment data
        deactivate Database

        Model --> Service : 7.2.3. Return comment entity
        deactivate Model

        Service --> Controller : 7.2.4. Return CommentBlogResponse
        deactivate Service
        Controller --> Route : 7.2.5. Return 200 OK + comment data
        deactivate Controller
        Route --> View : 7.2.6. Render comment detail
        deactivate Route
end

View --> User : 8. Display comment page content
deactivate View
@enduml
