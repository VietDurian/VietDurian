@startuml Export Product

actor Admin as "Admin"
boundary "ProductPage" as View 
participant ":productRoute" as Route 
control "authMiddleware" as Auth 
control "productController" as Controller 
participant ":productService" as Service 
entity "productModel" as Model 
database "MongoDB" as MongoDB 
participant ":exportHelper" as Helper 
hide footbox

Admin -> View: 1. Click "Export" button
activate Admin
activate View

View -> View: 2. Show export modal
activate View
deactivate View

opt Cancel Export
    View --> Admin: 2.1. Cancel export
end

Admin -> View: 3. Select export type (Excel/CSV)\nand apply filters (optional)
Admin -> View: 4. Confirm export

View -> Route: 5. GET /api/v1/product/export/{type}\n(params: name)
activate Route

Route -> Auth: 6. authenticateUser(req, res, next)
activate Auth

ref over Admin, MongoDB : Verifies token

Auth --> Route: 7. authentication success
deactivate Auth

Route -> Controller: 8. exportExcel(req, res) | exportCSV(req, res)
activate Controller

Controller -> Service: 9. getAllForExport(filters)
activate Service

Service -> Model: 10. getAllForExport(combinedFilters, maxLimit)
activate Model

Model -> MongoDB: 11. ExecuteQuery(find with filters)
activate MongoDB
MongoDB --> Model: 12. Return products array
deactivate MongoDB

Model --> Service: 13. Return products data
deactivate Model

Service --> Controller: 14. Return products array
deactivate Service

Controller -> Controller: 15. Check if products array is empty
activate Controller
deactivate Controller

opt No products found

    Controller --> Route: 15.1. Show error message
    Route --> View: 15.2. Show error message
    View --> Admin: 15.3. Display "No products found to export"
end

Controller -> Controller: 16. Generate file based on export type
activate Controller
deactivate Controller

alt Export Type = Excel

    Controller -> Helper: 16.1. generateProductExcelFile(products)
    activate Helper
    
    Helper --> Controller: 16.1.1. Return Excel buffer
    deactivate Helper
    
else Export Type = CSV
    Controller -> Helper: 16.2. generateProductCSVFile(products)
    activate Helper
    
    Helper --> Controller: 16.2.1. Return CSV string
    deactivate Helper
end

Controller --> Route: 17. Return 200 OK + file buffer/string
deactivate Controller

Route --> View: 18. Return file blob
deactivate Route


View --> Admin: 19. File downloaded successfully
deactivate Admin
deactivate View

@enduml