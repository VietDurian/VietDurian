@startuml 11.1_costStatistics
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control statisticRoute as Route
participant ":authMiddleware" as Middleware
control statisticController as Controller
participant ":statisticService" as Service
participant ":statisticModel" as Model
database Database as DB

activate User
User -> UI : 1. Open cost statistics page
activate UI
UI -> Route : 2. GET /statistic/cost?period=selectedPeriod
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 4. handleGetCostStatistics(userInfo, period)
deactivate Middleware
activate Controller
Controller -> Service : 5. getCostStatistics(userId, period)
activate Service
Service -> Model : 6. findCostData(userId, period)
activate Model
Model -> DB : 7. execute query aggregate
activate DB
DB --> Model : 8. Return cost data
deactivate DB
Model --> Service : 9. Return cost data
deactivate Model
Service -> Service : 10. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 10.1 Return error
    Controller --> Route : 10.2 Return error info
    Route --> UI : 10.3 Show error message
    UI --> User : 10.4 Display error message
end
Service -> Service : 11. calculateSummaries()
activate Service
deactivate Service
Service --> Controller : 12. Return success
deactivate Service
Controller --> Route : 13. Return success
deactivate Controller
Route --> UI : 14. Return success
deactivate Route
UI --> User : 15. Display cost statistics
deactivate UI
deactivate User

@enduml
