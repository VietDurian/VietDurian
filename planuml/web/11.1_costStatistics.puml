@startuml 11.1_costStatistics
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control statisticRoute as Route
participant ":authMiddleware" as Middleware
control statisticController as Controller
participant ":statisticService" as Service
participant ":statisticModel" as Model
database Database as DB

activate User
User -> UI : 1. Open cost statistics page
activate UI
UI -> Route : 2. GET /statistic/cost?period=selectedPeriod
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware --> Route : 4. User authenticated & authorized
deactivate Middleware
Route -> Controller : 5. handleGetCostStatistics(userInfo, period)
activate Controller
Controller -> Service : 6. getCostStatistics(userId, period)
activate Service
Service -> Model : 7. findCostData(userId, period)
activate Model
Model -> DB : 8. aggregate([{$match: {userId, period}}, {$group: {...}}])
activate DB
DB --> Model : 9. Return cost data
deactivate DB
Model --> Service : 10. Return cost data
deactivate Model
Service -> Service : 11. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 11.1 Return error
    Controller --> Route : 11.2 Return error info
    Route --> UI : 11.3 Show error message
    UI --> User : 11.4 Display error message
end
Service -> Service : 12. calculateSummaries()
activate Service
deactivate Service
Service --> Controller : 13. Return success
deactivate Service
Controller --> Route : 14. Return success
deactivate Controller
Route --> UI : 15. Return success
deactivate Route
UI --> User : 16. Display cost statistics
deactivate UI
deactivate User

@enduml
