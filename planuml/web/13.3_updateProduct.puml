@startuml 13.3_updateProduct
hide footbox
title Update Product

actor User as "Users"
boundary EditProductPage as View
participant ":ProductRoute" as Route
control "AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Open product edit form
activate View
activate User

User -> View : 2. Edit product fields and submit
View -> View : 3. Validate form input

opt Check validation
    View --> User : 3.1. Show validation error
end

    View -> Route : 4. PUT /products/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 6. Forward UpdateProductRequest(id, payload)
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process product update
    activate Service

alt Product not found
    Service -> Model : 8.1. Find product by ID
    activate Model

    Model -> Database : 8.1.1. Retrieve product data by ID
    activate Database
    Database --> Model : 8.1.2. Result (null)
    deactivate Database

    Model --> Service : 8.1.3. Return not found
    deactivate Model

        Service --> Controller : 8.1.4. Return not found result
        Controller --> Route : 8.1.5. Return 404 Not Found + message
        Route --> View : 8.1.6. Show error: "Product not found"
else Product exists
        Service -> Model : 8.2. Update product fields
        activate Model

        Model -> Database : 8.2.1. Persist updated product data
        activate Database
        Database --> Model : 8.2.2. Update success
        deactivate Database

        Model --> Service : 8.2.3. Return updated entity
        deactivate Model

        Service --> Controller : 8.2.4. Return UpdateProductResponse
        deactivate Service
        Controller --> Route : 8.2.5. Return 200 OK + updated product data
        deactivate Controller
        Route --> View : 8.2.6. Show success message
        deactivate Route
end

View --> User : 9. Display result (success or error)
deactivate View
deactivate User
@enduml