@startuml 13.3_updateProduct
hide footbox
title Update Product

actor User
boundary EditProductPage as View
control ProductRoute as Route
participant ":AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
participant ":ProductModel" as Model
database Database as Database

User -> View : 1. Open product edit form
activate View

User -> View : 2. Edit product fields and submit
View -> View : 3. Validate form input

opt Check validation
    View --> User : 3.1. Show validation error
end

    View -> Route : 4. PUT /products/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 6. Authentication success
    Middleware -> Controller : 7. Forward UpdateProductRequest(id, payload)
    deactivate Middleware
    activate Controller

    Controller -> Service : 8. Process product update
    activate Service

alt Product not found
    Service -> Model : 9.1. Find product by ID
    activate Model

    Model -> Database : 9.1.1. Retrieve product data by ID
    activate Database
    Database --> Model : 9.1.2. Result (null)
    deactivate Database

    Model --> Service : 9.1.3. Return not found
    deactivate Model

        Service --> Controller : 9.1.4. Return not found result
        Controller --> Route : 9.1.5. Return 404 Not Found + message
        Route --> View : 9.1.6. Show error: "Product not found"
else Product exists
        Service -> Model : 9.2. Update product fields
        activate Model

        Model -> Database : 9.2.1. Persist updated product data
        activate Database
        Database --> Model : 9.2.2. Update success
        deactivate Database

        Model --> Service : 9.2.3. Return updated entity
        deactivate Model

        Service --> Controller : 9.2.4. Return UpdateProductResponse
        deactivate Service
        Controller --> Route : 9.2.5. Return 200 OK + updated product data
        deactivate Controller
        Route --> View : 9.2.6. Show success message
        deactivate Route
end

View --> User : 10. Display result (success or error)
deactivate View
@enduml
