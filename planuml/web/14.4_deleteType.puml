@startuml 14.4_deleteType
hide footbox
title Delete Type

actor User
boundary TypePage as View
control TypeRoute as Route
participant ":AuthMiddleware" as Middleware
control "TypeController" as Controller
participant ":TypeService" as Service
participant ":TypeModel" as Model
database Database as Database

User -> View : 1. Click "Delete" on a type
activate View
View --> User : 2. Show confirmation dialog
User -> View : 3. Confirm delete

    View -> Route : 4. DELETE /types/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 6. Authentication success
    Middleware -> Controller : 7. Forward DeleteTypeRequest(typeId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 8. Process type deletion
    activate Service

alt Type not found
    Service -> Model : 9.1. Find type by ID
    activate Model

    Model -> Database : 9.1.1. Retrieve type data by ID
    activate Database
    Database --> Model : 9.1.2. Result (null)
    deactivate Database

    Model --> Service : 9.1.3. Return not found
    deactivate Model

        Service --> Controller : 9.1.4. Return not found result
        Controller --> Route : 9.1.5. Return 404 Not Found + message
        Route --> View : 9.1.6. Show error: "Type not found"
else Type exists
        Service -> Model : 9.2. Delete type by ID
        activate Model

        Model -> Database : 9.2.1. Persist deletion
        activate Database
        Database --> Model : 9.2.2. Delete success
        deactivate Database

        Model --> Service : 9.2.3. Return deletion result
        deactivate Model

        Service --> Controller : 9.2.4. Return DeleteTypeResponse
        deactivate Service
        Controller --> Route : 9.2.5. Return 200 OK + success message
        deactivate Controller
        Route --> View : 9.2.6. Show delete success
        deactivate Route
end

View --> User : 10. Display result (success or error)
deactivate View
@enduml
