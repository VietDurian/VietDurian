@startuml ViewConversation

actor Admin
boundary "AdminDashboard" as View #lightblue
participant ":chatRoute" as Route #lightblue
control "authMiddleware" as Auth #Orange
control "chatController" as Controller #lightblue
participant ":chatService" as Service #lightblue
entity "conversationModel" as Model #lightblue
database "MongoDB" as MongoDB #yellow

    Admin -> View: 1. Access conversation page
    activate Admin
    activate View

    View -> Route: 2. GET /api/v1/chat/conversations
    activate Route

    Route -> Auth: 3. authenticateAdmin(req, res, next)
    activate Auth
    
    ref over Admin, View, Route, Auth, Controller, Service, Model, MongoDB : 4. Middleware verifies access token & admin role

    Auth --> Route: 5. Authentication success
    deactivate Auth

    Route -> Controller: 6. getAllConversation(req, res)
    activate Controller

    Controller -> Service: 7. getAllConversation()
    activate Service

    Service -> Model: 8. getAll()
    activate Model

    Model -> MongoDB: 9. ExecuteQuery()
    activate MongoDB
    MongoDB --> Model: 10. return conversations list
    deactivate MongoDB

    Model --> Service: 11. return conversations
    deactivate Model

   alt Conversations exist

        Service --> Controller: 12.1. return conversations

        Controller --> Route: 12.1.1. return conversations data

        Route --> View: 12.1.2. display conversations list

        View --> Admin: 12.1.3. show conversations
    else Conversations Empty

        Service --> Controller: 12.2. return empty list
        deactivate Service

        Controller --> Route: 12.2.1. return empty data
        deactivate Controller

        Route --> View: 12.2.2. display "No conversations found"
        deactivate Route

        View --> Admin: 12.2.3. show message
        deactivate View
        deactivate Admin
    end


@enduml