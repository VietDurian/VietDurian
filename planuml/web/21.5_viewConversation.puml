@startuml ViewConversation

actor Admin
boundary "AdminDashboard" as View 
participant ":chatRoute" as Route 
control "authMiddleware" as Auth 
control "chatController" as Controller 
participant ":chatService" as Service 
entity "conversationModel" as Model 
database "MongoDB" as MongoDB 
hide footbox

    Admin -> View: 1. Access conversation page
    activate Admin
    activate View

    View -> Route: 2. GET /api/v1/chat/conversations
    activate Route

    Route -> Auth: 3. authenticateAdmin(req, res, next)
    activate Auth
    
    ref over Admin, MongoDB : Verifies token

    Auth --> Route: 4. Authentication success
    deactivate Auth

    Route -> Controller: 5. getAllConversation(req, res)
    activate Controller

    Controller -> Service: 6. getAllConversation()
    activate Service

    Service -> Model: 7. getAll()
    activate Model

    Model -> MongoDB: 8. ExecuteQuery()
    activate MongoDB
    MongoDB --> Model: 9. return conversations list
    deactivate MongoDB

    Model --> Service: 10. return conversations
    deactivate Model

    Service -> Service: 11. checkCreatedConversations()
    activate Service    
    deactivate Service

    opt database error
        Service --> Controller: 11. Return badrequest
        Controller --> Route: 11.2. Return error response
        Route --> View: 11.3. Return error response
        View -> Admin: 11.4. Display error message
    end

    Service -> Service: 12. checkConversationsExistence()
    activate Service
    deactivate Service

   alt Conversations exist

        Service --> Controller: 12.1. return conversations

        Controller --> Route: 12.1.1. return conversations data

        Route --> View: 12.1.2. display conversations list

        View --> Admin: 12.1.3. show conversations
    else Conversations Empty

        Service --> Controller: 12.2. return empty list
        deactivate Service

        Controller --> Route: 12.2.1. return empty data
        deactivate Controller

        Route --> View: 12.2.2. display "No conversations found"
        deactivate Route

        View --> Admin: 12.2.3. show message
        deactivate View
        deactivate Admin
    end


@enduml