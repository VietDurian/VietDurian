@startuml ViewConversation

actor Admin
boundary "AdminDashboard" as View 
participant ":chatRoute" as Route 
control "authMiddleware" as Auth 
control "chatController" as Controller 
participant ":chatService" as Service 
entity "conversationModel" as Model 
database "MongoDB" as MongoDB 
hide footbox

    Admin -> View: 1. Access conversation page
    activate Admin
    activate View

    View -> Route: 2. GET /api/v1/chat/conversations
    activate Route

    Route -> Auth: 3. authenticateAdmin(req, res, next)
    activate Auth
    
    ref over Admin, MongoDB : Verifies token

    Auth -> Controller: 4. next(req)
    deactivate Auth
    activate Controller

    Controller -> Service: 5. getAllConversation()
    activate Service

    Service -> Model: 6. find()
    activate Model

    Model -> MongoDB: 7. ExecuteQuery()
    activate MongoDB
    MongoDB --> Model: 8. return conversations list
    deactivate MongoDB

    Model --> Service: 9. return conversations
    deactivate Model

    Service -> Service: 10. checkConversationsExistence()
    activate Service
    deactivate Service

   alt Conversations exist

        Service --> Controller: 10.1. return conversations

        Controller --> Route: 10.1.1. return conversations data

        Route --> View: 10.1.2. display conversations list
        View --> Admin: 10.1.3. show conversations
    else Conversations Empty

        Service --> Controller: 10.2. return empty list
        deactivate Service

        Controller --> Route: 10.2.1. return empty data
        deactivate Controller

        Route --> View: 10.2.2. display "No conversations found"
        deactivate Route

        View --> Admin: 10.2.3. show message
        deactivate View
        deactivate Admin
    end


@enduml