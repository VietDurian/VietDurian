@startuml 13.6_searchProduct
hide footbox
title Search Product

actor User as "Users"
boundary ProductPage as View
participant ":ProductRoute" as Route
control "AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Enter search keyword and submit
activate View
activate User


    View -> Route : 2. GET /products/search?keyword=&page=&size=&sort=
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 4. Forward SearchProductRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 5. Process product search
    activate Service

    Service -> Model : 6. Normalize keyword
    activate Model

    Model -> Database : 7. Retrieve matched products by keyword
    activate Database
    Database --> Model : 8. Result set
    deactivate Database

    Model --> Service : 9. Return search results + paging info
    deactivate Model

alt No products match
    Service --> Controller : 10.1. Return empty result
    Controller --> Route : 10.1.1. Return 200 OK + empty list/message
    Route --> View : 10.1.2. Show "No products found" + keep keyword
else Products match
    Service --> Controller : 10.2. Return SearchProductResponse
    deactivate Service
    Controller --> Route : 10.2.1. Return 200 OK + matched products data
    deactivate Controller
    Route --> View : 10.2.2. Render search results + pagination
    deactivate Route
end

View --> User : 11. Display search result
deactivate View
deactivate User
@enduml
