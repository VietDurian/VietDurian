@startuml 10.2_viewDiary
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary diaryPage as UI
control diaryRoute as Route
control diaryController as Controller
participant ":diaryService" as Service
participant ":diaryModel" as Model
database Database as DB

activate User
User -> UI : 1. Click view diary entry
activate UI
UI -> Route : 2. GET /diary/entry/:id
activate Route
Route -> Controller : 3. handleViewDiary(diaryId)
activate Controller
Controller -> Service : 4. getDiary(diaryId)
activate Service
Service -> Model : 5. findById(diaryId)
activate Model
Model -> DB : 6. execute query findOne
activate DB
DB --> Model : 7. Return result 
deactivate DB
Model --> Service : 8. Return result
deactivate Model
Service -> Service : 9. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 9.1 Return error
    Controller --> Route : 9.2 Return error info
    Route --> UI : 9.3 Show error message
    UI --> User : 9.4 Display error message
end
Service -> Service : 10. checkNotFound()
activate Service
deactivate Service
opt diary not found
    Service --> Controller : 10.1 Return error
    Controller --> Route : 10.2 Return error info
    Route --> UI : 10.3 Show error message
    UI --> User : 10.4 Display error message
end
Service -> Service : 11. mapToDiaryDTO()
activate Service
deactivate Service
Service --> Controller : 12. Return success
deactivate Service
Controller --> Route : 13. Return success
deactivate Controller
Route --> UI : 14. Return success
deactivate Route
UI --> User : 15. Show diary content
deactivate UI
deactivate User

@enduml
