@startuml 9.3_viewPublicProfile
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary profileViewPage as UI
control profileController as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Click view public profile
activate UI
UI -> Controller : 2. GET /profile/public/:userId 
activate Controller
Controller -> ProfileService : 5. getPublicProfile(userId)
activate ProfileService
ProfileService -> UserService : 6. findById(userId)
activate UserService
UserService -> UserModel : 7. findOne()
activate UserModel
UserModel -> DB : 8. execute query findOne
activate DB
DB --> UserModel : 9. Return user document
deactivate DB
UserModel --> UserService : 10. Return raw result
deactivate UserModel
UserService -> UserService : 11. checkQuerySuccess()
activate UserService
deactivate UserService
opt database error
    UserService --> ProfileService : 11.1 Return badrequest
    ProfileService --> Controller : 11.2 Return error response
    Controller --> UI : 11.3 Return error response
    UI --> User : 11.4 Display error message
end
UserService --> ProfileService : 12. Return user entity
deactivate UserService
ProfileService -> ProfileService : 13. filterPublicData()
activate ProfileService
deactivate ProfileService
ProfileService -> ProfileService : 14. mapToPublicDTO()
activate ProfileService
deactivate ProfileService
ProfileService --> Controller : 15. Return success + public data
deactivate ProfileService
Controller --> UI : 16. Return success + public data (200)
deactivate Controller
UI --> UI : 17. Render public profile
activate UI
deactivate UI
UI --> User : 18. Display public profile
deactivate UI
deactivate User

@enduml
