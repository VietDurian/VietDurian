@startuml SearchConversation

actor Admin
boundary "ConversationListPage" as View 
participant ":chatRoute" as Route 
control "authMiddleware" as Auth 
control "chatController" as Controller 
participant ":chatService" as Service 
entity "conversationModel" as Model
database "MongoDB" as MongoDB 
hide footbox

    Admin -> View: 1. Enter search keyword (username)
    activate Admin
    activate View

        View -> Route: 2. GET /api/v1/chat/conversations{searchKeyword}
        activate Route

        Route -> Auth: 3. authenticateAdmin(req, res, next)
        activate Auth
        
        ref over Admin, MongoDB : Verify token

        Auth -> Controller: 4. next(req)
        deactivate Auth
        activate Controller

        Controller -> Service: 5. getAllConversation(keyword)
        activate Service

        Service -> Model: 6 . find(keyword)
        activate Model

        Model -> MongoDB: 7. ExecuteQuery() - Aggregate with user lookup
        activate MongoDB
        MongoDB --> Model: 8. return all conversations with user info
        deactivate MongoDB

        Model --> Service: 9. return conversations list
        deactivate Model

        Service -> Service: 10. check keyword & filter conversations
        activate Service
        deactivate Service

        alt Conversations found

            Service --> Controller: 10.1. return conversations list
            
            Controller --> Route: 10.1.1. return conversations data

            Route --> View: 10.1.2. display conversations list
            View --> Admin: 10.1.3. show filtered conversations
        else No conversations found
            Service --> Controller: 10.2. return empty list
            deactivate Service

            Controller --> Route: 10.2.1. return empty data
            deactivate Controller

            Route --> View: 10.2.2. display no conversations message
            deactivate Route

            View --> Admin: 10.2.3. show "No conversations found"
            deactivate View
            deactivate Admin
        end

@enduml
