@startuml 12.1_viewUserList
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardScreen as UI
control userManagementRoute as Route
participant ":authMiddleware" as Middleware
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Open user list page
activate UI
UI -> Route : 2. GET /user/list
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token & Check Role
Middleware --> Route : 4. User authenticated & authorized
deactivate Middleware
Route -> Controller : 5. handleGetUserList(userInfo)
activate Controller
Controller -> Service : 6. getUserList()
activate Service
Service -> Model : 7. findAllUsers()
activate Model
Model -> DB : 8. find()
activate DB
DB --> Model : 9. Return user documents
deactivate DB
Model --> Service : 10. Return user documents
deactivate Model
Service -> Service : 11. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 11.1 Return error
    Controller --> Route : 11.2 Return error info
    Route --> UI : 11.3 Show error message
    UI -> User : 11.4 Display error message
end
Service -> Service : 12. mapToUserDTO()
activate Service
deactivate Service
Service --> Controller : 13. Return success
deactivate Service
Controller --> Route : 14. Return success
deactivate Controller
Route --> UI : 15. Return success
deactivate Route
UI -> UI : 16. Render user list
activate UI
deactivate UI
UI -> User : 17. Display user list
deactivate UI
deactivate User

@enduml
