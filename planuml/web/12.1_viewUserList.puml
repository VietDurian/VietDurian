@startuml 12.1_viewUserList
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardPage as UI
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Open user list page
activate UI
UI -> Controller : 2. GET /user/list
activate Controller
Controller -> Service : 5. getUserList()
activate Service
Service -> Model : 6. findAllUsers()
activate Model
Model -> DB : 7. execute query find
activate DB
DB --> Model : 8. Return user documents
deactivate DB
Model --> Service : 9. Return user documents
deactivate Model
Service -> Service : 10. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 10.1 Return error
    Controller --> UI : 10.2 Return error info
    UI --> User : 10.3 Display error message
end
Service -> Service : 11. mapToUserDTO()
activate Service
deactivate Service
Service --> Controller : 12. Return success
deactivate Service
Controller --> UI : 13. Return success
deactivate Controller

UI --> User : 15. Display user list
deactivate UI
deactivate User

@enduml
