actor User
boundary ProductPage
participant ":ProductRoute" as ProductRoute
control AuthMiddleware
control ProductController
participant ":ProductService" as ProductService
participant ":ProductModel" as ProductModel
database Database

User->ProductPage: 1. Enter search keyword and submit
activate ProductPage
activate User

ProductPage->ProductRoute: 2. GET /products/search?keyword=&page=&size=&sort=
activate ProductRoute

ProductRoute->AuthMiddleware: 3. AuthenticateUser(req, res, next)
activate AuthMiddleware
#ref over User, Database: Verifies token
AuthMiddleware->ProductController: 4. Forward SearchProductRequest
deactivate AuthMiddleware
activate ProductController

ProductController->ProductService: 5. Process product search
activate ProductService

ProductService->ProductModel: 6. Normalize keyword
activate ProductModel

ProductModel->Database: 7. Retrieve matched products by keyword
activate Database
Database-->ProductModel: 8. Result set
deactivate Database

ProductModel-->ProductService: 9. Return search results + paging info
deactivate ProductModel

alt No products match
    ProductService-->ProductController: 10.1. Return empty result
    ProductController-->ProductRoute: 10.1.1. Return 200 OK + empty list/message
    ProductRoute-->ProductPage: 10.1.2. Show "No products found" + keep keyword
    ProductPage-->User: 10.1.3. Show "No products found" + keep keyword
else Products match
    ProductService-->ProductController: 10.2. Return SearchProductResponse
    deactivate ProductService
    ProductController-->ProductRoute: 10.2.1. Return 200 OK + matched products data
    deactivate ProductController
    ProductRoute-->ProductPage: 10.2.2. Render search results + pagination
    deactivate ProductRoute


ProductPage-->User: 10.2.3. Display search result
end
deactivate ProductPage
deactivate User
