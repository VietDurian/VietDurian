@startuml 12.6_viewAccountList
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Users
boundary AccountPermissionListPage as UI
control permissionAccountController as Controller
participant ":permissionAccountService" as Service
participant ":permissionAccountModel" as Model
database Database as DB

activate Users
Users -> UI : 1. Open account permission list page
activate UI
UI -> Controller : 2. GET /permission/accounts
activate Controller
Controller -> Service : 3. getAccountPermissionList()
activate Service
Service -> Model : 4. findEligibleAccounts()
activate Model
Model -> DB : 5. find()
activate DB
DB --> Model : 6. Return account documents
deactivate DB
Model --> Service : 7. Return accounts
deactivate Model
Service -> Service : 8. mapToAccountPermissionDTO()
activate Service
deactivate Service
Service --> Controller : 9. Return success + accounts
deactivate Service
Controller --> UI : 10. Return success + accounts
deactivate Controller
UI -> UI : 11. Render account permission list
activate UI
deactivate UI
UI --> Users : 12. Display account permission list
deactivate UI
deactivate Users

@enduml