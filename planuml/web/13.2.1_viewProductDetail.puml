@startuml 13.2.1_viewProductDetail
hide footbox
title View Product Detail

actor User
boundary ProductDetailPage as View
control ProductRoute as Route
participant ":AuthMiddleware" as Middleware
control "ProductController" as Controller
participant ":ProductService" as Service
participant ":ProductModel" as Model
database Database as Database

User -> View : 1. Open product detail page
activate View

    View -> Route : 2. GET /products/{id}
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 4. Authentication success
    Middleware -> Controller : 5. Forward ViewProductDetailRequest(productId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 6. Process product detail retrieval
    activate Service

alt Product not found
    Service -> Model : 7.1. Find product by ID
    activate Model

    Model -> Database : 7.1.1. Retrieve product data by ID
    activate Database
    Database --> Model : 7.1.2. Result (null)
    deactivate Database

    Model --> Service : 7.1.3. Return not found
    deactivate Model

        Service --> Controller : 7.1.4. Return not found result
        Controller --> Route : 7.1.5. Return 404 Not Found + message
        Route --> View : 7.1.6. Show "Product not found"
else Product found
        Service -> Model : 7.2. Find product by ID
        activate Model

        Model -> Database : 7.2.1. Retrieve product data by ID
        activate Database
        Database --> Model : 7.2.2. Product data
        deactivate Database

        Model --> Service : 7.2.3. Return product entity
        deactivate Model

        Service --> Controller : 7.2.4. Return ProductDetailResponse
        deactivate Service
        Controller --> Route : 7.2.5. Return 200 OK + product data
        deactivate Controller
        Route --> View : 7.2.6. Render product detail
        deactivate Route
end

View --> User : 8. Display detail page content (detail or error)
deactivate View
@enduml
