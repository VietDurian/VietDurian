@startuml 13.2.1_viewProductDetail
hide footbox

actor User as "Users"
boundary ProductDetailPage as View
control "ProductController" as Controller
participant ":ProductService" as Service
entity "ProductModel" as Model
database Database as Database

User -> View : 1. Open product detail page
activate View
activate User

    View -> Controller : 2. GET /products/{id}
    activate Controller

    Controller -> Service : 5. Process product detail retrieval
    activate Service

alt Product not found
    Service -> Model : 6.1. Find product by ID
    activate Model

    Model -> Database : 6.1.1. Retrieve product data by ID
    activate Database
    Database --> Model : 6.1.2. Result (null)
    deactivate Database

    Model --> Service : 6.1.3. Return not found
    deactivate Model

        Service --> Controller : 6.1.4. Return not found result
        Controller --> View : 6.1.5. Return 404 Not Found + message
        View --> User : 6.1.6. Show "Product not found"
else Product found
        Service -> Model : 6.2. Find product by ID
        activate Model

        Model -> Database : 6.2.1. Retrieve product data by ID
        activate Database
        Database --> Model : 6.2.2. Product data
        deactivate Database

        Model --> Service : 6.2.3. Return product entity
        deactivate Model

        Service --> Controller : 6.2.4. Return ProductDetailResponse
        deactivate Service
        Controller --> View : 6.2.5. Return 200 OK + product data
        deactivate Controller
        View -> View : 6.2.6. Render product detail
end

View --> User : 7. Display detail page content (detail or error)
deactivate View
deactivate User
@enduml
