@startuml DeleteReport

actor Admin
boundary "ReportPage" as View 
participant ":reportRoute" as Route 
control ":authMiddleware" as Auth 
control "reportController" as Controller 
participant ":reportService" as Service 
entity "reportModel" as Model 
database "MongoDB" as MongoDB 
hide footbox

Admin -> View: 1. Select a report and click "Delete" icon
activate Admin
activate View

View -> View: 2. Show confirmation dialog
activate View
deactivate View

opt Cancel Deletion
    View --> Admin: 2.1. Cancel deletion 
end

Admin -> View: 3. Click "Confirm" button

View -> Route: 4. DELETE /api/v1/report/{reportId}
activate Route

Route -> Auth: 5. authenticateUser(req, res, next)
activate Auth
ref over Admin, MongoDB : Verifies token

    Auth -> Controller: 6. next(req)
    deactivate Auth
    activate Controller

    Controller -> Service: 7. deleteReport(reportId)
    activate Service

    Service -> Model: 8. findByIdAndDelete(reportId)
    activate Model
    Model -> MongoDB: 9. Delete report by ID
    activate MongoDB
    MongoDB --> Model: 10. Return result
    deactivate MongoDB
    Model --> Service: 11. Return success
    deactivate Model

    Service -> Service: 12. checkReportExistence()
    activate Service
    deactivate Service

    alt Report exists
        Service --> Controller: 12.1. Return success
        Controller --> Route: 12.1.1. Return message success
        Route --> View: 12.1.2. Refresh report list
        View --> Admin: 12.1.3. Show "Report deleted successfully"
    else Report not found
        Service --> Controller: 12.2. Return error
        deactivate Service

        Controller --> Route: 12.2.1. Return 404 Not Found
        deactivate Controller

        Route --> View: 12.2.2. Show error
        deactivate Route

        View --> Admin: 12.2.3. Display "Report not found or already deleted"
        deactivate View
        deactivate Admin
    end
@enduml
