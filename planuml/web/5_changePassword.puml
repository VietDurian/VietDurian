@startuml 5_changePassword
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary authChangePasswordPage as UI
control authRoute as Route
participant ":authMiddleware" as AuthMiddleware
control authController as Controller
participant ":authService" as AuthService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Open change password page
activate UI
UI --> User : 2. Render change password form
User -> UI : 3. Enter form (old password, new password, confirm)
User -> UI : 4. Click change password button
UI -> UI : 5. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 5.1 Display validation error
end

UI -> Route : 6. POST /auth/change-password
activate Route
Route -> AuthMiddleware : 7. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token 
AuthMiddleware --> Route : 8. User authenticated & authorized
deactivate AuthMiddleware
Route -> Controller : 9. handleChangePassword(oldPassword, newPassword)
activate Controller
Controller -> Controller : 10. validate input
activate Controller
deactivate Controller
opt invalid input data
    Controller --> Route : 10.1 Return error
    Route --> UI : 10.2 Return error
    UI --> User : 10.3 Display error message
end

Controller -> AuthService : 11. changePassword(userId, oldPassword, newPassword)
activate AuthService
AuthService -> UserService : 12. findById(userId)
activate UserService
UserService -> UserModel : 13. findOne()
activate UserModel
UserModel -> DB : 14. findOne()
activate DB
DB --> UserModel : 15. Return user document (or null)
deactivate DB
UserModel --> UserService : 16. Return user entity (or null)
deactivate UserModel
UserService --> AuthService : 17. Return user entity (or null)
deactivate UserService
AuthService -> AuthService : 18. checkDatabaseError()
activate AuthService
deactivate AuthService
opt database error
    AuthService --> Controller : 18.1 Return error
    Controller --> Route : 18.2 Return error
    Route --> UI : 18.3 Return error
    UI --> User : 18.4 Display error message
end
AuthService -> AuthService : 19. checkNotFound()
activate AuthService
deactivate AuthService
opt user not found
    AuthService --> Controller : 19.1 Return error
    Controller --> Route : 19.2 Return error
    Route --> UI : 19.3 Return error
    UI --> User : 19.4 Display error message
end

AuthService -> AuthService : 20. verifyOldPassword(oldPassword, user.password)
activate AuthService
deactivate AuthService
opt old password incorrect
    AuthService --> Controller : 20.1 Return error
    Controller --> Route : 20.2 Return error
    Route --> UI : 20.3 Return error
    UI --> User : 20.4 Display error message
end

AuthService -> AuthService : 21. hashNewPassword(newPassword)
activate AuthService
deactivate AuthService
AuthService -> UserService : 22. updatePassword(userId, hashedPassword)
activate UserService
UserService -> UserModel : 23. updateOne()
activate UserModel
UserModel -> DB : 24. updateOne()
activate DB
DB --> UserModel : 25. Return modified count
deactivate DB
UserModel --> UserService : 26. Return result
deactivate UserModel
UserService -> UserService : 27. checkDatabaseError()
activate UserService
deactivate UserService
opt database error
    UserService --> AuthService : 27.1 Return error
    AuthService --> Controller : 27.2 Return error
    Controller --> Route : 27.3 Return error
    Route --> UI : 27.4 Return error
    UI --> User : 27.5 Display error message
end
UserService --> AuthService : 28. Return success
deactivate UserService
AuthService --> Controller : 29. Return success
deactivate AuthService
Controller --> Route : 30. Return success
deactivate Controller
Route --> UI : 31. Return success
deactivate Route
UI --> User : 32. Display success message
deactivate UI
deactivate User
@enduml
