@startuml 5_changePassword
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary authChangePasswordPage as UI
control authRoute as Route
participant ":authMiddleware" as AuthMiddleware
control authController as Controller
participant ":authService" as AuthService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Open change password page
activate UI
UI --> User : 2. Render change password form
User -> UI : 3. Enter form (old password, new password, confirm)
User -> UI : 4. Click change password button
UI -> UI : 5. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 5.1 Display validation error
end

UI -> Route : 6. POST /auth/change-password
activate Route
Route -> AuthMiddleware : 7. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token 
AuthMiddleware -> Controller : 8. handleChangePassword(oldPassword, newPassword)
deactivate AuthMiddleware
activate Controller
Controller -> Controller : 9. validate input
activate Controller
deactivate Controller
opt invalid input data
    Controller --> Route : 9.1 Return error
    Route --> UI : 9.2 Return error
    UI --> User : 9.3 Display error message
end

Controller -> AuthService : 10. changePassword(userId, oldPassword, newPassword)
activate AuthService
AuthService -> UserService : 11. findById(userId)
activate UserService
UserService -> UserModel : 12. findOne()
activate UserModel
UserModel -> DB : 13. execute query findOne
activate DB
DB --> UserModel : 14. Return user document
deactivate DB
UserModel --> UserService : 15. Return user entity 
deactivate UserModel
UserService --> AuthService : 16. Return user entity 
deactivate UserService
AuthService -> AuthService : 17. checkDatabaseError()
activate AuthService
deactivate AuthService
opt database error
    AuthService --> Controller : 17.1 Return error
    Controller --> Route : 17.2 Return error
    Route --> UI : 17.3 Return error
    UI --> User : 17.4 Display error message
end
AuthService -> AuthService : 18. checkNotFound()
activate AuthService
deactivate AuthService
opt user not found
    AuthService --> Controller : 18.1 Return error
    Controller --> Route : 18.2 Return error
    Route --> UI : 18.3 Return error
    UI --> User : 18.4 Display error message
end

AuthService -> AuthService : 19. verifyOldPassword(oldPassword, user.password)
activate AuthService
deactivate AuthService
opt old password incorrect
    AuthService --> Controller : 19.1 Return error
    Controller --> Route : 19.2 Return error
    Route --> UI : 19.3 Return error
    UI --> User : 19.4 Display error message
end

AuthService -> AuthService : 20. hashNewPassword(newPassword)
activate AuthService
deactivate AuthService
AuthService -> UserService : 21. updatePassword(userId, hashedPassword)
activate UserService
UserService -> UserModel : 22. updateOne()
activate UserModel
UserModel -> DB : 23. execute query updateOne()
activate DB
DB --> UserModel : 24. Return modified count
deactivate DB
UserModel --> UserService : 25. Return result
deactivate UserModel
UserService -> UserService : 26. checkDatabaseError()
activate UserService
deactivate UserService
opt database error
    UserService --> AuthService : 26.1 Return error
    AuthService --> Controller : 26.2 Return error
    Controller --> Route : 26.3 Return error
    Route --> UI : 26.4 Return error
    UI --> User : 26.5 Display error message
end
UserService --> AuthService : 27. Return success
deactivate UserService
AuthService --> Controller : 28. Return success
deactivate AuthService
Controller --> Route : 29. Return success
deactivate Controller
Route --> UI : 30. Return success
deactivate Route
UI --> User : 31. Display success message
deactivate UI
deactivate User
@enduml
