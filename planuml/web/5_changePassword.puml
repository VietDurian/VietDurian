@startuml 5_changePassword
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary authChangePasswordScreen as UI
control authRoute as Route
participant ":authMiddleware" as AuthMiddleware
control authController as Controller
participant ":authService" as AuthService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Open change password page
activate UI
UI --> User : 2. Render change password form
User -> UI : 3. Enter form (old password, new password, confirm)
User -> UI : 4. Click change password button
UI -> UI : 5. Validate input
activate UI
deactivate UI
opt validation error
    UI -> User : 5.1 Display validation error
end

UI -> Route : 6. POST /auth/change-password (with JWT token)
activate Route
Route -> AuthMiddleware : 7. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token & Check Role
AuthMiddleware --> Route : 8. User authenticated & authorized
deactivate AuthMiddleware
Route -> Controller : 9. handleChangePassword(oldPassword, newPassword)
activate Controller
Controller -> Controller : 10. validate input
activate Controller
deactivate Controller
opt invalid input data
    Controller --> Route : 10.1 Return badrequest
    Route --> UI : 10.2 Return error response
    UI -> User : 10.3 Display error message
end

Controller -> AuthService : 11. changePassword(userId, oldPassword, newPassword)
activate AuthService
AuthService -> UserService : 12. findById(userId)
activate UserService
UserService -> UserModel : 13. findOne()
activate UserModel
UserModel -> DB : 14. findOne()
activate DB
DB --> UserModel : 15. Return user document (or null)
deactivate DB
UserModel --> UserService : 16. Return user entity (or null)
deactivate UserModel
UserService --> AuthService : 17. Return user entity (or null)
deactivate UserService
AuthService -> AuthService : 18. checkNotFound()
activate AuthService
deactivate AuthService
opt user not found
    AuthService --> Controller : 18.1 Return notfound
    Controller --> Route : 18.2 Return error response
    Route --> UI : 18.3 Return error response
    UI -> User : 18.4 Display error message
end

AuthService -> AuthService : 19. verifyOldPassword(oldPassword, user.password)
activate AuthService
deactivate AuthService
opt old password incorrect
    AuthService --> Controller : 19.1 Return badrequest
    Controller --> Route : 19.2 Return error response
    Route --> UI : 19.3 Return error response
    UI -> User : 19.4 Display error message
end

AuthService -> AuthService : 20. hashNewPassword(newPassword)
activate AuthService
deactivate AuthService
AuthService -> UserService : 21. updatePassword(userId, hashedPassword)
activate UserService
UserService -> UserModel : 22. updateOne()
activate UserModel
UserModel -> DB : 23. updateOne()
activate DB
DB --> UserModel : 24. Return modified count
deactivate DB
UserModel --> UserService : 25. Confirm password updated
deactivate UserModel
UserService --> AuthService : 26. Return success
deactivate UserService
AuthService --> Controller : 27. Return success
deactivate AuthService
Controller --> Route : 28. Return success
deactivate Controller
Route --> UI : 29. Return success
deactivate Route
UI -> User : 30. Display "Password changed successfully"
deactivate UI
deactivate User
@enduml
