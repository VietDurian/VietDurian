@startuml 10.4_deleteDiary
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary diaryScreen as UI
control diaryRoute as Route
participant ":authMiddleware" as Middleware
control diaryController as Controller
participant ":diaryService" as Service
participant ":diaryModel" as Model
database Database as DB

activate User
User -> UI : 1. Click delete diary entry
activate UI
UI -> Route : 2. DELETE /diary/entry/:id
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token & Check Role
Middleware --> Route : 4. User authenticated & authorized
deactivate Middleware
Route -> Controller : 5. handleDeleteDiary(userInfo, diaryId)
activate Controller
Controller -> Service : 6. deleteDiary(diaryId)
activate Service
Service -> Model : 7. findById(diaryId)
activate Model
Model -> DB : 8. findOne({_id: diaryId})
activate DB
DB --> Model : 9. Return result (document/null/error)
deactivate DB
Model --> Service : 10. Return result
deactivate Model
Service -> Service : 11. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 11.1 Return error
    Controller --> Route : 11.2 Return error info
    Route --> UI : 11.3 Show error message
    UI -> User : 11.4 Display error message
end
Service -> Service : 12. Check if diary result is null
activate Service
deactivate Service
opt diary not found
    Service --> Controller : 12.1 Return error
    Controller --> Route : 12.2 Return error info
    Route --> UI : 12.3 Show error message
    UI -> User : 12.4 Display error message
end
Service -> Model : 13. delete(diaryId)
activate Model
Model -> DB : 14. deleteOne({_id: diaryId})
activate DB
DB --> Model : 15. Return result
deactivate DB
Model --> Service : 16. Return delete result
deactivate Model
Service -> Service : 17. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 17.1 Return error
    Controller --> Route : 17.2 Return error info
    Route --> UI : 17.3 Show error message
    UI -> User : 17.4 Display error message
end
Service -> Service : 18. mapToDiaryDTO()
activate Service
deactivate Service
Service --> Controller : 19. Return success
deactivate Service
Controller --> Route : 20. Return success
deactivate Controller
Route --> UI : 21. Return success
deactivate Route
UI -> UI : 22. Display success message
activate UI
deactivate UI
UI -> User : 23. Display diary deleted confirmation
deactivate UI
deactivate User

@enduml
