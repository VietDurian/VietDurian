@startuml 10.4_deleteDiary
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary diaryPage as UI
control diaryRoute as Route
participant ":authMiddleware" as Middleware
control diaryController as Controller
participant ":diaryService" as Service
participant ":diaryModel" as Model
database Database as DB

activate User
User -> UI : 1. Click delete diary entry
activate UI
UI -> Route : 2. DELETE /diary/entry/:id
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token
Middleware -> Controller : 4. handleDeleteDiary(userInfo, diaryId)
deactivate Middleware
activate Controller
Controller -> Service : 5. deleteDiary(diaryId)
activate Service
Service -> Model : 6. findById(diaryId)
activate Model
Model -> DB : 7. execute query findOne
activate DB
DB --> Model : 8. Return result
deactivate DB
Model --> Service : 9. Return result
deactivate Model
Service -> Service : 10. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 10.1 Return error
    Controller --> Route : 10.2 Return error info
    Route --> UI : 10.3 Show error message
    UI --> User : 10.4 Display error message
end
Service -> Service : 11. Check if diary result is null
activate Service
deactivate Service
opt diary not found
    Service --> Controller : 11.1 Return error
    Controller --> Route : 11.2 Return error info
    Route --> UI : 11.3 Show error message
    UI --> User : 11.4 Display error message
end
Service -> Model : 12. delete(diaryId)
activate Model
Model -> DB : 13. execute query deleteOne
activate DB
DB --> Model : 14. Return result
deactivate DB
Model --> Service : 15. Return delete result
deactivate Model
Service -> Service : 16. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 16.1 Return error
    Controller --> Route : 16.2 Return error info
    Route --> UI : 16.3 Show error message
    UI --> User : 16.4 Display error message
end
Service -> Service : 17. mapToDiaryDTO()
activate Service
deactivate Service
Service --> Controller : 18. Return success
deactivate Service
Controller --> Route : 19. Return success
deactivate Controller
Route --> UI : 20. Return success
deactivate Route

UI --> User : 21. Display diary deleted confirmation
deactivate UI
deactivate User

@enduml
