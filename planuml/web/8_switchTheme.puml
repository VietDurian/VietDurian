@startuml 8_switchTheme
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary profileThemePage as UI
control profileRoute as Route
participant ":authMiddleware" as AuthMiddleware
control profileController as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
participant ":UserModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Click theme toggle
activate UI
UI -> Route : 2. POST /profile/switch-theme 
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token
AuthMiddleware -> Controller : 4. handleSwitchTheme(userId, theme)
deactivate AuthMiddleware
activate Controller
Controller -> ProfileService : 5. switchTheme(userId, theme)
activate ProfileService

deactivate UserService
ProfileService -> UserService : 6. updateTheme(userId, theme)
activate UserService
UserService -> UserModel : 7. updateOne()
activate UserModel
UserModel -> DB : 8. execute query updateOne()
activate DB
DB --> UserModel : 9. Return modified count (or 0 if failed)
deactivate DB
UserModel -> UserModel : 10. checkUpdateSuccess()
activate UserModel
deactivate UserModel
opt database error
    UserModel --> UserService : 10.1 Return badrequest
    UserService --> ProfileService : 10.2 Return error response
    ProfileService --> Controller : 10.3 Return error response
    Controller --> Route : 10.4 Return error response
    Route --> UI : 10.5 Return error response
    UI --> User : 10.6 Display error message
end
UserModel --> UserService : 11. Confirm theme updated
deactivate UserModel
UserService --> ProfileService : 12. Return success
deactivate UserService
ProfileService --> Controller : 13. Return success
deactivate ProfileService
Controller --> Route : 14. Return success
deactivate Controller
Route --> UI : 15. Return success
deactivate Route
UI -> UI : 16. Apply theme change
activate UI
deactivate UI
UI --> User : 17. Display updated theme
deactivate UI
deactivate User
@enduml
