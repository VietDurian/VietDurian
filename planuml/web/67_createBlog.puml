@startuml 67_createBlog
hide footbox

actor User as "Content Expert" 
boundary BlogPage as View
control "BlogController" as Controller
participant ":BlogService" as Service
entity "KnowledgeBlogModel" as Model
entity "KnowledgeBlockModel" as Model
database Database as Database


User -> View : 1. Enter title, content, image & submit
activate View
activate User
View -> View : 2. Validate input
activate View
deactivate View
opt Invalid Input or fields left empty
    View --> User : 2.1. Display errors message
end

View -> Controller : 3. Create blog request
activate Controller

Controller -> Service : 4. createKnowledgeBlog(blogData)
activate Service

Service -> Model : 5. save(blogData)
activate Model

Model -> Database : 6. save new blog
activate Database
Database --> Model : 7. Return result
deactivate Database

Model --> Service : 8. Return created entity
deactivate Model

Service -> Service : 9. check blog creation status
activate Service
deactivate Service

alt Blog creation successful
    Service --> Controller : 9.1. Return BlogResponse

    Controller --> View : 9.1.1. Show success message

    View --> User : 9.1.2. Display 'Blog created successfully'
else Blog creation failed
    Service --> Controller : 9.2. Return failure
    deactivate Service

    Controller --> View : 9.2.1. Show error message
    deactivate Controller

    View --> User : 9.2.2. Display 'Blog creation failed'
    deactivate View
    deactivate User
end
@enduml
