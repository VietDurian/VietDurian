@startuml 10.3_updateDiary
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary diaryPage as UI
control diaryRoute as Route
participant ":authMiddleware" as Middleware
control diaryController as Controller
participant ":diaryService" as Service
participant ":diaryModel" as Model
database Database as DB

activate User
User -> UI : 1. Click edit diary entry
activate UI
User -> UI : 2. Edit diary entry details
User -> UI : 3. Click submit button
UI -> Route : 4. PUT /diary/entry/:id 
activate Route
Route -> Middleware : 5. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token 
Middleware -> Controller : 6. handleUpdateDiary(userInfo, diaryId, data)
deactivate Middleware
activate Controller
Controller -> Controller : 7. Validate input
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 7.1 Return error
    Route --> UI : 7.2 Show error message
    UI --> User : 7.3 Display error message
end
Controller -> Service : 8. updateDiary(diaryId, data)
activate Service
Service -> Model : 9. findById(diaryId)
activate Model
Model -> DB : 10. execute query findOne
activate DB
DB --> Model : 11. Return result 
deactivate DB
Model --> Service : 12. Return result
deactivate Model
Service -> Service : 13. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 13.1 Return error
    Controller --> Route : 13.2 Return error info
    Route --> UI : 13.3 Show error message
    UI --> User : 13.4 Display error message
end
Service -> Service : 14. Check if diary result is null
activate Service
deactivate Service
opt diary not found
    Service --> Controller : 14.1 Return error
    Controller --> Route : 14.2 Return error info
    Route --> UI : 14.3 Show error message
    UI --> User : 14.4 Display error message
end
Service -> Model : 15. update(diaryId, updateData)
activate Model
Model -> DB : 16. execute query updateOne
activate DB
DB --> Model : 17. Return result
deactivate DB
Model --> Service : 18. Return update result
deactivate Model
Service -> Service : 19. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 19.1 Return error
    Controller --> Route : 19.2 Return error info
    Route --> UI : 19.3 Show error message
    UI --> User : 19.4 Display error message
end
Service -> Service : 20. mapToDiaryDTO()
activate Service
deactivate Service
Service --> Controller : 21. Return success
deactivate Service
Controller --> Route : 22. Return success
deactivate Controller
Route --> UI : 23. Return success
deactivate Route

UI --> User : 24. Display updated diary entry
deactivate UI
deactivate User

@enduml
