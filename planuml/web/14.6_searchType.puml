@startuml 14.6_searchType
hide footbox
title Search Type

actor User
boundary TypePage as View
control TypeRoute as Route
participant ":AuthMiddleware" as Middleware
control "TypeController" as Controller
participant ":TypeService" as Service
participant ":TypeModel" as Model
database Database as Database

User -> View : 1. Enter search keyword and submit
activate View

    View -> Route : 2. GET /types/search?keyword=&page=&size=&sort=
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 4. Authentication success
    Middleware -> Controller : 5. Forward SearchTypeRequest
    deactivate Middleware
    activate Controller

    Controller -> Service : 6. Process type search
    activate Service

    Service -> Model : 7. Normalize keyword
    activate Model

    Model -> Database : 8. Retrieve matched types by keyword
    activate Database
    Database --> Model : 9. Result set
    deactivate Database

    Model --> Service : 10. Return search results + paging info
    deactivate Model

alt No types match
    Service --> Controller : 10.1. Return empty result
    Controller --> Route : 10.1.1. Return 200 OK + empty list/message
    Route --> View : 10.1.2. Show "No types found" + keep keyword
else Types match
    Service --> Controller : 10.2. Return SearchTypeResponse
    deactivate Service
    Controller --> Route : 10.2.1. Return 200 OK + matched types data
    deactivate Controller
    Route --> View : 10.2.2. Render search results + pagination
    deactivate Route
end

View --> User : 11. Display search result
deactivate View
@enduml
