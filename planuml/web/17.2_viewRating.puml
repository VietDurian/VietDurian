@startuml 17.2_viewRating
hide footbox
title View Rating

actor User as "Users"
boundary RatingPage as View
participant ":RatingRoute" as Route
control "AuthMiddleware" as Middleware
control "RatingController" as Controller
participant ":RatingService" as Service
entity "RatingModel" as Model
database Database as Database

User -> View : 1. Open rating page
activate View
activate User

    View -> Route : 2. GET /ratings/{id}
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 4. Forward ViewRatingRequest(ratingId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 5. Process rating retrieval
    activate Service

alt Rating not found
    Service -> Model : 6.1. Find rating by ID
    activate Model

    Model -> Database : 6.1.1. Retrieve rating data by ID
    activate Database
    Database --> Model : 6.1.2. Result (null)
    deactivate Database

    Model --> Service : 6.1.3. Return not found
    deactivate Model

        Service --> Controller : 6.1.4. Return not found result
        Controller --> Route : 6.1.5. Return 404 Not Found + message
        Route --> View : 6.1.6. Show "Rating not found"
else Rating found
        Service -> Model : 6.2. Find rating by ID
        activate Model

        Model -> Database : 6.2.1. Retrieve rating data by ID
        activate Database
        Database --> Model : 6.2.2. Rating data
        deactivate Database

        Model --> Service : 6.2.3. Return rating entity
        deactivate Model

        Service --> Controller : 6.2.4. Return RatingResponse
        deactivate Service
        Controller --> Route : 6.2.5. Return 200 OK + rating data
        deactivate Controller
        Route --> View : 6.2.6. Render rating detail
        deactivate Route
end

View --> User : 7. Display rating page content
deactivate View
deactivate User
@enduml
