@startuml 17.2_viewRating
hide footbox
title View Rating

actor User
boundary RatingPage as View
control RatingRoute as Route
participant ":AuthMiddleware" as Middleware
control "RatingController" as Controller
participant ":RatingService" as Service
participant ":RatingModel" as Model
database Database as Database

User -> View : 1. Open rating page
activate View

    View -> Route : 2. GET /ratings/{id}
    activate Route

    Route -> Middleware : 3. AuthenticateUser(req, res, next)
    activate Middleware
    Middleware --> Route : 4. Authentication success
    Middleware -> Controller : 5. Forward ViewRatingRequest(ratingId)
    deactivate Middleware
    activate Controller

    Controller -> Service : 6. Process rating retrieval
    activate Service

alt Rating not found
    Service -> Model : 7.1. Find rating by ID
    activate Model

    Model -> Database : 7.1.1. Retrieve rating data by ID
    activate Database
    Database --> Model : 7.1.2. Result (null)
    deactivate Database

    Model --> Service : 7.1.3. Return not found
    deactivate Model

        Service --> Controller : 7.1.4. Return not found result
        Controller --> Route : 7.1.5. Return 404 Not Found + message
        Route --> View : 7.1.6. Show "Rating not found"
else Rating found
        Service -> Model : 7.2. Find rating by ID
        activate Model

        Model -> Database : 7.2.1. Retrieve rating data by ID
        activate Database
        Database --> Model : 7.2.2. Rating data
        deactivate Database

        Model --> Service : 7.2.3. Return rating entity
        deactivate Model

        Service --> Controller : 7.2.4. Return RatingResponse
        deactivate Service
        Controller --> Route : 7.2.5. Return 200 OK + rating data
        deactivate Controller
        Route --> View : 7.2.6. Render rating detail
        deactivate Route
end

View --> User : 8. Display rating page content
deactivate View
@enduml
