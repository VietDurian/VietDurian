@startuml UC44_UpdateReport

actor Admin as "Admin"
boundary "ReportPage" as View
participant ":reportBlogRoute" as Route
control "authMiddleware" as Auth
control "reportBlogController" as Controller
participant ":reportBlogService" as Service
entity "reportBlogModel" as Model
database "MongoDB" as MongoDB
hide footbox

    Admin -> View: 1. Select a report to update
    activate View
    activate Admin

    View -> Route: 2. PATCH /api/v1/report/:id
    activate Route
    Route -> Auth: 3. authenticateUser(req, res, next)

    activate Auth
    ref over Admin, MongoDB : Verifies token

    Auth -> Controller: 4. next(req)
    deactivate Auth
    activate Controller

    Controller -> Service: 5. updateReport(id)
    activate Service

    Service -> Model: 6. findByIdAndUpdate(id, updateData)
    activate Model

    Model -> MongoDB: 7. Update report query
    activate MongoDB
    MongoDB --> Model: 8. Return report
    deactivate MongoDB

    Model --> Service: 9. Return result
    deactivate Model

    Service -> Service: 10. checkReportUpdate()
    activate Service
    deactivate Service

    alt Report not found
        Service --> Controller: 10.1. Return error "Report not found"
        Controller --> Route: 10.1.1. Return 404
        Route --> View: 10.1.2. Show error message
        View --> Admin: 10.1.3. Display "Report not found"
    else Report found
        Service -> Model: 10.2. Update report fields (status)
        activate Model
        Model -> MongoDB: 10.2.1. Execute update query
        activate MongoDB
        MongoDB --> Model: 10.2.2. Return update result
        deactivate MongoDB
        Model --> Service: 10.2.3. Return updated report
        deactivate Model

        Service --> Controller: 10.2.4. Return success
        deactivate Service
        Controller --> Route: 10.2.5. Return success message
        deactivate Controller
        Route --> View: 10.2.6. Return success message
        deactivate Route
        View --> Admin: 10.2.7. Show "Report updated successfully"
        deactivate View
        deactivate Admin
    end

@enduml
