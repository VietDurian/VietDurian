@startuml UC44_UpdateReport

actor Admin as "Admin"
boundary "ReportPage" as View
participant ":reportRoute" as Route
control "authMiddleware" as Auth
control "reportController" as Controller
participant ":reportService" as Service
entity "reportModel" as Model
database "MongoDB" as MongoDB
hide footbox

    Admin -> View: 1. Select a report to update
    activate View
    activate Admin

    View -> Route: 2. PATCH /api/v1/report/:id
    activate Route
    Route -> Auth: 3. authenticateUser(req, res, next)

    activate Auth
    ref over Admin, MongoDB : Verifies token
    Auth --> Route: 4. authentication success
    deactivate Auth

    Route -> Controller: 5. updateReport(req, res)
    activate Controller

    Controller -> Service: 6. updateReport(id)
    activate Service

    Service -> Model: 7. updateReport(id)
    activate Model

    Model -> MongoDB: 8. Update report query
    activate MongoDB
    MongoDB --> Model: 9. Return report
    deactivate MongoDB

    Model --> Service: 10. Return result
    deactivate Model

    Service -> Service: 11. checkCreationSuccess()
    activate Service
    deactivate Service

    opt database error
        Service --> Controller: 11.1. Return badrequest
        Controller --> Route: 11.2. Return error response
        Route --> View: 11.3. Return error response
        View -> Admin: 11.4. Display error message
    end

    Service -> Service: 12. checkReportUpdate()
    activate Service
    deactivate Service

    alt Report not found
        Service --> Controller: 12.1. Return error "Report not found"
        Controller --> Route: 12.1.1. Return 404
        Route --> View: 12.1.2. Show error message
        View --> Admin: 12.1.3. Display "Report not found"
    else Report found
        Service -> Model: 12.2. Update report fields (status)
        activate Model
        Model -> MongoDB: 12.2.1. Execute update query
        activate MongoDB
        MongoDB --> Model: 12.2.2. Return update result
        deactivate MongoDB
        Model --> Service: 12.2.3. Return updated report
        deactivate Model

        Service --> Controller: 12.2.4. Return success
        deactivate Service
        Controller --> Route: 12.2.5. Return success message
        deactivate Controller
        Route --> View: 12.2.6. Return success message
        deactivate Route
        View --> Admin: 12.2.7. Show "Report updated successfully"
        deactivate View
        deactivate Admin
    end

@enduml
