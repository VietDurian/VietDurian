@startuml 9_viewDiaryDetail
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Farmer as "Users"
boundary DiaryDetailPage as UI 
control diaryController as Controller 
participant ":diaryService" as Service 
participant ":diaryModel" as Model 
database Database as DB 

activate Farmer
activate UI
Farmer -> UI : 1. Farmer click a specific diary

UI -> Controller : 2. Get diary detail request
activate Controller

Controller -> Service : 3. getDiaryDetails(diaryId)
activate Service
Service -> Model : 4. findById(diaryId)
activate Model
Model -> DB : 5. Execute query
activate DB
DB --> Model : 6. Return result
deactivate DB
Model --> Service : 7. Return diary details
deactivate Model
    Service -> Service : 8. check diary details
activate Service
deactivate Service
    Service --> Controller : 9. Return data
    deactivate Service
    Controller --> UI : 10. Show diary details
    deactivate Controller
    UI --> Farmer : 11. Display diary details
    deactivate UI
    deactivate Farmer
@enduml