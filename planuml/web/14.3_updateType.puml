@startuml 14.3_updateType
hide footbox
title Update Type

actor User as "Users"
boundary EditTypePage as View
participant ":TypeRoute" as Route
control "AuthMiddleware" as Middleware
control "TypeController" as Controller
participant ":TypeService" as Service
entity "TypeModel" as Model
database Database as Database

User -> View : 1. Open type edit form
activate View
activate User

User -> View : 2. Edit type fields and submit
View -> View : 3. Validate form input

opt Check validation
    View --> User : 3.1. Show validation error
end

    View -> Route : 4. PUT /types/{id}
    activate Route

    Route -> Middleware : 5. AuthenticateUser(req, res, next)
    activate Middleware
    ref over User, Database : Verifies token
    Middleware -> Controller : 6. Forward UpdateTypeRequest(id, payload)
    deactivate Middleware
    activate Controller

    Controller -> Service : 7. Process type update
    activate Service

alt Type not found
    Service -> Model : 8.1. Find type by ID
    activate Model

    Model -> Database : 8.1.1. Retrieve type data by ID
    activate Database
    Database --> Model : 8.1.2. Result (null)
    deactivate Database

    Model --> Service : 8.1.3. Return not found
    deactivate Model

        Service --> Controller : 8.1.4. Return not found result
        Controller --> Route : 8.1.5. Return 404 Not Found + message
        Route --> View : 8.1.6. Show error: "Type not found"
else Type exists
        Service -> Model : 8.2. Update type fields
        activate Model

        Model -> Database : 8.2.1. Persist updated type data
        activate Database
        Database --> Model : 8.2.2. Update success
        deactivate Database

        Model --> Service : 8.2.3. Return updated entity
        deactivate Model

        Service --> Controller : 8.2.4. Return UpdateTypeResponse
        deactivate Service
        Controller --> Route : 8.2.5. Return 200 OK + updated type data
        deactivate Controller
        Route --> View : 8.2.6. Show success message
        deactivate Route
end

View --> User : 9. Display result (success or error)
deactivate View
deactivate User
@enduml
