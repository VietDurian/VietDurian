@startuml SendMessage

actor User as "Users"
boundary "ConversationDetailPage" as View
participant ":chatRoute" as Route 
control "authMiddleware" as Auth 
control "chatController" as Controller 
participant ":chatService" as Service 
entity "messageModel" as MsgModel 
entity "conversationModel" as ConvModel 
database "MongoDB" as MongoDB 
participant "Socket Server" as Socket 
hide footbox

    User -> View: 1. Type message content
    activate User
    activate View

    User -> View: 2. Click send button (or Enter)

    View -> Route: 3. POST /api/v1/chat/message
    activate Route

    Route -> Auth: 4. authenticateUser(req, res, next)
    activate Auth
    
    ref over User, MongoDB : Verifies token

    Auth -> Controller: 5. next(req)
    deactivate Auth
    activate Controller

    Controller -> Service: 6. sendMessage(readerId, senderId, content)
    activate Service

    Service -> ConvModel: 7. findById(readerId)
    activate ConvModel

    ConvModel -> MongoDB: 8. ExecuteQuery()
    activate MongoDB
    MongoDB --> ConvModel: 9. Return conversation or null
    deactivate MongoDB

    ConvModel --> Service: 10. Return conversation
    deactivate ConvModel

    opt Conversation not found
        Service -> ConvModel: 11. insertOne(conversationData)
        activate ConvModel
        ConvModel -> MongoDB: 11.1. ExecuteQuery()
        activate MongoDB
        MongoDB --> ConvModel: 11.2. Return new conversation
        deactivate MongoDB
        ConvModel --> Service: 11.3. Return conversationId
        deactivate ConvModel
    end

    Service -> MsgModel: 12. insertOne(messageData)
    activate MsgModel

    MsgModel -> MongoDB: 13. ExecuteQuery()
    activate MongoDB
    MongoDB --> MsgModel: 14. Return new message
    deactivate MongoDB

    MsgModel --> Service: 15. Return new message
    deactivate MsgModel

    Service -> ConvModel: 16. findByIdAndUpdate(conversationId, messageId, readerId)
    activate ConvModel

    ConvModel -> MongoDB: 17. ExecuteQuery()
    activate MongoDB
    MongoDB --> ConvModel: 18. Return updated conversation
    deactivate MongoDB

    ConvModel --> Service: 19. Return updated conversation
    deactivate ConvModel

    Service --> Controller: 20. Return message result
    deactivate Service

    par Emit new message to other user
        Controller -> Socket: 20.1. emitNewMessage(messageData, receiverId)
        activate Socket
        Socket --> View: 20.1.1. Broadcast 'new_message' to other user
        deactivate Socket
    else Emit conversation update to admin
        Controller -> Service: 20.2. getAllConversation()
        activate Service
        Service -> ConvModel: 20.2.1. find()
        activate ConvModel
        ConvModel -> MongoDB: 20.2.2. ExecuteQuery()
        activate MongoDB
        MongoDB --> ConvModel: 20.2.3. Return all conversations
        deactivate MongoDB
        ConvModel --> Service: 20.2.4. Return conversations
        deactivate ConvModel
        Service --> Controller: 20.2.5. Return conversations
        deactivate Service
        
        Controller -> Socket: 20.2.6. emitConversationsUpdate(conversations)
        activate Socket
        Socket --> View: 20.2.7. Broadcast to admin
        deactivate Socket
    end

    View --> User: 21. Display new message in chat
    deactivate View
    deactivate User

@enduml
