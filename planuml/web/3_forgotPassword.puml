@startuml 3_forgotPassword
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor Users
boundary ForgotPasswordPage as UI
boundary OtpVerificationPage as OtpUI
control authController as Controller
participant ":authService" as AuthService
participant ":userModel" as UserModel
participant ":otpModel" as OtpModel
database Database as DB

Users -> UI : 1. Input email
activate Users
activate UI
Users -> UI : 2. Submit forgot request
UI -> UI : 3. Validate input
activate UI
deactivate UI
opt Validation error
    UI -> Users : 3.1 Show validation error
end

UI -> Controller : 4. POST /auth/forgot-password
activate Controller
Controller -> AuthService : 6. forgotPassword()
activate AuthService

AuthService -> UserModel : 7. findByEmail()
activate UserModel
UserModel -> DB : 8. findOne()
activate DB
DB --> UserModel : 9. Return user (or null)
deactivate DB
UserModel --> AuthService : 10. Return result
deactivate UserModel

AuthService -> AuthService : 11. Check user presence
activate AuthService
deactivate AuthService
opt User not found
    AuthService --> Controller : 11.1 Return error
    Controller --> UI : 11.2 Return error
    UI --> Users : 11.3 Display error message
else User found
    AuthService -> AuthService : 12. generateOtpAndResetToken()
    activate AuthService
    deactivate AuthService
    AuthService -> OtpModel : 13. storeOtp()
    activate OtpModel
    OtpModel -> DB : 14. insertOne()
    activate DB
    DB --> OtpModel : 15. Confirm stored
    deactivate DB
    OtpModel --> AuthService : 16. Confirm OTP saved
    deactivate OtpModel
    AuthService -> AuthService : 17. prepareResetEmail()
    activate AuthService
    deactivate AuthService
    AuthService --> Controller : 18. Return success
    deactivate AuthService
    Controller --> UI : 19. Return success
    deactivate Controller
    UI --> Users : 21. Display reset email notification
    deactivate UI
end

Users -> OtpUI : 22. Open OTP verification page
activate OtpUI
OtpUI -> Users : 23. Prompt for OTP
Users -> OtpUI : 24. Enter OTP code
OtpUI -> OtpUI : 25. Validate OTP input
activate OtpUI
deactivate OtpUI
opt Validation error
    OtpUI -> Users : 25.1 Display validation error
end

OtpUI -> Controller : 26. POST /otp/verify
activate Controller
Controller -> AuthService : 28. verifyOtp()
activate AuthService
AuthService -> OtpModel : 29. Query OTP
activate OtpModel
OtpModel -> DB : 30. Execute query
activate DB
DB --> OtpModel : 31. Return OTP record (or null)
deactivate DB
OtpModel --> AuthService : 32. Return result
deactivate OtpModel
AuthService -> AuthService : 33. Validate OTP and expiry
activate AuthService
deactivate AuthService

opt OTP invalid or expired
    AuthService --> Controller : 33.1 Return error
    Controller --> OtpUI : 33.2 Return error
    OtpUI --> Users : 33.3 Display error message
else OTP valid
    AuthService -> OtpModel : 34. markOtpUsed()
    activate OtpModel
    OtpModel -> DB : 35. updateOne()
    activate DB
    DB --> OtpModel : 36. Confirm update
    deactivate DB
    OtpModel --> AuthService : 37. Confirm updated
    deactivate OtpModel
    AuthService -> AuthService : 38. generateResetToken()
    activate AuthService
    deactivate AuthService
    AuthService --> Controller : 39. Return success with reset token
    deactivate AuthService
    Controller --> OtpUI : 41. Return success with reset token
        deactivate Controller
    OtpUI --> Users : 42. Navigate to login page
    deactivate OtpUI
    deactivate Users
end
@enduml