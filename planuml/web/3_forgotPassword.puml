@startuml 6_forgotPassword
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary AuthForgotPasswordScreen as UI
control AuthRoute as Route
control AuthController as Controller
participant ":AuthService" as AuthService
participant ":UserService" as UserService
participant ":UserModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Open forgot password page
activate UI
UI --> User : 2. Render forgot password form
User -> UI : 3. Enter email
User -> UI : 4. Click send reset link
UI -> UI : 5. Validate email input
activate UI
deactivate UI
opt validation error
    UI -> User : 5.1 Display validation error
end

UI -> Route : 6. POST /auth/forgot-password (email)
activate Route
Route -> Controller : 7. handleForgotPassword(email)
activate Controller
Controller -> Controller : 8. validate input
activate Controller
deactivate Controller
opt invalid email data
    Controller --> Route : 8.1 Return {code: 4001, message: 'Invalid email'}
    Route --> UI : 8.2 Return error response
    UI -> User : 8.3 Display error message
end

Controller -> AuthService : 9. forgotPassword(email)
activate AuthService
AuthService -> UserService : 10. findByEmail(email)
activate UserService
UserService -> UserModel : 11. findOne()
activate UserModel
UserModel -> DB : 12. findOne()
activate DB
DB --> UserModel : 13. Return user document (or null)
deactivate DB
UserModel --> UserService : 14. Return user entity (or null)
deactivate UserModel
UserService --> AuthService : 15. Return user entity (or null)
deactivate UserService
AuthService -> AuthService : 16. checkNotFound()
activate AuthService
deactivate AuthService
opt user not found
    AuthService --> Controller : 16.1 Return {code: 4004, message: 'User not found'}
    Controller --> Route : 16.2 Return error response
    Route --> UI : 16.3 Return error response
    UI -> User : 16.4 Display error message
end

AuthService -> AuthService : 17. generateResetToken()
activate AuthService
deactivate AuthService
AuthService -> AuthService : 18. prepareResetEmail()
activate AuthService
deactivate AuthService
AuthService -> UserService : 19. updateResetToken(email, token)
activate UserService
UserService -> UserModel : 20. updateOne()
activate UserModel
UserModel -> DB : 21. updateOne()
activate DB
DB --> UserModel : 22. Return modified count
deactivate DB
UserModel --> UserService : 23. Confirm token stored
deactivate UserModel
UserService --> AuthService : 24. Confirm updated
deactivate UserService
AuthService --> Controller : 25. Return {code: 1000, data: {message: 'Reset email sent'}}
deactivate AuthService
Controller --> Route : 22. Return {code: 1000, data: {message: 'Reset email sent'}}
deactivate Controller
Route --> UI : 23. Return {code: 1000, data: {message: 'Reset email sent'}}
deactivate Route
UI -> User : 24. Display reset email notification
deactivate UI
deactivate User
@enduml