@startuml 12.1.1_viewUserDetail
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary dashboardScreen as UI
control userManagementRoute as Route
participant ":authMiddleware" as Middleware
control userManagementController as Controller
participant ":userManagementService" as Service
participant ":userManagementModel" as Model
database Database as DB

activate User
User -> UI : 1. Click on user to view details
activate UI
UI -> Route : 2. GET /userManagement/detail/:userId
activate Route
Route -> Middleware : 3. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token & Check Role
Middleware --> Route : 4. User authenticated & authorized
deactivate Middleware
Route -> Controller : 5. handleGetUserDetail(userInfo, userId)
activate Controller
Controller -> Service : 6. getUserDetail(userId)
activate Service
Service -> Model : 7. findById(userId)
activate Model
Model -> DB : 8. findOne({_id: userId})
activate DB
DB --> Model : 9. Return user document
deactivate DB
Model --> Service : 10. Return user document
deactivate Model
Service -> Service : 11. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 11.1 Return error
    Controller --> Route : 11.2 Return error info
    Route --> UI : 11.3 Show error message
    UI -> User : 11.4 Display error message
end
Service -> Service : 12. checkNotFound()
activate Service
deactivate Service
opt user not found
    Service --> Controller : 12.1 Return error
    Controller --> Route : 12.2 Return error info
    Route --> UI : 12.3 Show error message
    UI -> User : 12.4 Display error message
end
Service -> Service : 13. mapToUserDetailDTO()
activate Service
deactivate Service
Service --> Controller : 14. Return success
deactivate Service
Controller --> Route : 15. Return success
deactivate Controller
Route --> UI : 16. Return success
deactivate Route
UI -> UI : 17. Render user detail profile
activate UI
deactivate UI
UI -> User : 18. Display user detailed information
deactivate UI
deactivate User

@enduml
