@startuml 8_switchTheme
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary profileThemeScreen as UI
control profileRoute as Route
participant ":authMiddleware" as AuthMiddleware
control profileController as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
participant ":UserModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Click theme toggle
activate UI
UI -> Route : 2. POST /profile/switch-theme 
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token & Check Role
AuthMiddleware --> Route : 4. User authenticated & authorized
deactivate AuthMiddleware
Route -> Controller : 5. handleSwitchTheme(userId, theme)
activate Controller
Controller -> ProfileService : 6. switchTheme(userId, theme)
activate ProfileService

deactivate UserService
ProfileService -> UserService : 7. updateTheme(userId, theme)
activate UserService
UserService -> UserModel : 8. updateOne()
activate UserModel
UserModel -> DB : 9. updateOne()
activate DB
DB --> UserModel : 10. Return modified count (or 0 if failed)
deactivate DB
UserModel -> UserModel : 11. checkUpdateSuccess()
activate UserModel
deactivate UserModel
opt database error
    UserModel --> UserService : 11.1 Return badrequest
    UserService --> ProfileService : 11.2 Return error response
    ProfileService --> Controller : 11.3 Return error response
    Controller --> Route : 11.4 Return error response
    Route --> UI : 11.5 Return error response
    UI --> User : 11.6 Display error message
end
UserModel --> UserService : 12. Confirm theme updated
deactivate UserModel
UserService --> ProfileService : 13. Return success
deactivate UserService
ProfileService --> Controller : 14. Return success
deactivate ProfileService
Controller --> Route : 15. Return success
deactivate Controller
Route --> UI : 16. Return success
deactivate Route
UI -> UI : 17. Apply theme change
activate UI
deactivate UI
UI --> User : 18. Display updated theme
deactivate UI
deactivate User
@enduml
