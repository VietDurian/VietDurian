@startuml 9.6_editGardenRecord
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary gardenRecordScreen as UI
control gardenRoute as Route
participant ":authMiddleware" as Middleware
control gardenController as Controller
participant ":gardenService" as Service
participant ":gardenModel" as Model
database Database as DB

activate User
User -> UI : 1. Click edit garden record
activate UI
User -> UI : 2. Edit garden record details
User -> UI : 3. Click submit button
UI -> UI : 4. Validate input
activate UI
deactivate UI
opt validation error
    UI --> User : 4.1 Display error message
end
UI -> Route : 5. PUT /garden/record/:id
activate Route
Route -> Middleware : 6. authenticateUser(req) & authorizeRole()
activate Middleware
ref over User, DB: Verify Token & Check Role
Middleware --> Route : 7. User authenticated & authorized
deactivate Middleware
Route -> Controller : 8. handleEditGardenRecord(userInfo, gardenId)
activate Controller
Controller -> Controller : 9. Validate input
activate Controller
deactivate Controller
opt validation error
    Controller --> Route : 9.1 Return error
    Route --> UI : 9.2 Show error message
    UI --> User : 9.3 Display error message
end
Controller -> Service : 10. editGardenRecord(gardenId, data)
activate Service
Service -> Model : 11. findById(gardenId)
activate Model
Model -> DB : 12. findOne({_id: gardenId})
activate DB
DB --> Model : 13. Return result
deactivate DB
Model --> Service : 14. Return garden entity
deactivate Model
Service -> Service : 15. checkNotFound()
activate Service
deactivate Service
opt garden record not found
    Service --> Controller : 15.1 Return error
    Controller --> Route : 15.2 Return error info
    Route --> UI : 15.3 Show error message
    UI --> User : 15.4 Display error message
end
Service -> Model : 16. update(gardenId, updateData)
activate Model
Model -> DB : 17. updateOne({_id: gardenId}, {$set: {...}})
activate DB
DB --> Model : 18. Return result
deactivate DB
Model --> Service : 19. Return update result
deactivate Model
Service -> Service : 20. checkDatabaseError()
activate Service
deactivate Service
opt database error
    Service --> Controller : 20.1 Return error
    Controller --> Route : 20.2 Return error info
    Route --> UI : 20.3 Show error message
    UI --> User : 20.4 Display error message
end
Service -> Service : 21. mapToGardenDTO()
activate Service
deactivate Service
Service --> Controller : 22. Return success
deactivate Service
Controller --> Route : 23. Return success
deactivate Controller
Route --> UI : 24. Return success
deactivate Route
UI -> UI : 25. Display success message
activate UI
deactivate UI
UI --> User : 26. Display updated garden record
deactivate UI
deactivate User

@enduml
