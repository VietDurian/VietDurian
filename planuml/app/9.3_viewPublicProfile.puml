@startuml 9.3_viewPublicProfile
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary profileViewScreen as UI
control profileRoute as Route
participant ":authMiddleware" as AuthMiddleware
control profileController as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Click view public profile
activate UI
UI -> Route : 2. GET /profile/public/:userId 
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token & Check Role
AuthMiddleware --> Route : 4. User authenticated & authorized
deactivate AuthMiddleware
Route -> Controller : 5. handleGetPublicProfile(userId)
activate Controller
Controller -> ProfileService : 6. getPublicProfile(userId)
activate ProfileService
ProfileService -> UserService : 7. findById(userId)
activate UserService
UserService -> UserModel : 8. findOne()
activate UserModel
UserModel -> DB : 9. findOne()
activate DB
DB --> UserModel : 10. Return user document | null | dbError
deactivate DB
UserModel --> UserService : 11. Return raw result
deactivate UserModel
UserService -> UserService : 12. checkQuerySuccess()
activate UserService
deactivate UserService
opt database error
    UserService --> ProfileService : 12.1 Return badrequest
    ProfileService --> Controller : 12.2 Return error response
    Controller --> Route : 12.3 Return error response
    Route --> UI : 12.4 Return error response
    UI --> User : 12.5 Display error message
end
UserService --> ProfileService : 13. Return user entity
deactivate UserService
ProfileService -> ProfileService : 14. filterPublicData()
activate ProfileService
deactivate ProfileService
ProfileService -> ProfileService : 15. mapToPublicDTO()
activate ProfileService
deactivate ProfileService
ProfileService --> Controller : 16. Return success + public data
deactivate ProfileService
Controller --> Route : 17. Return success + public data (200)
deactivate Controller
Route --> UI : 18. Return success + public data (200)
deactivate Route
UI --> UI : 19. Render public profile
activate UI
deactivate UI
UI --> User : 20. Display public profile
deactivate UI
deactivate User

@enduml
