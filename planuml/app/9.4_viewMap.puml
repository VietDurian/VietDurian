@startuml 9.4_viewMap
skinparam monochrome true
skinparam shadowing false
skinparam sequenceArrowThickness 1
hide footbox

actor User
boundary mapViewScreen as UI
control profileRoute as Route
participant ":authMiddleware" as AuthMiddleware
control profileController as Controller
participant ":profileService" as ProfileService
participant ":userService" as UserService
participant ":userModel" as UserModel
database Database as DB

activate User
User -> UI : 1. Click open map
activate UI
UI -> Route : 2. GET /profile/map 
activate Route
Route -> AuthMiddleware : 3. authenticateUser(req) & authorizeRole()
activate AuthMiddleware
ref over User, DB: Verify Token & Check Role
AuthMiddleware --> Route : 4. User authenticated & authorized
deactivate AuthMiddleware
Route -> Controller : 5. handleGetMap(userId)
activate Controller
Controller -> ProfileService : 6. getMapData(userId)
activate ProfileService
ProfileService -> UserService : 7. getNurseryLocations(userId)
activate UserService
UserService -> UserModel : 8. find()
activate UserModel
UserModel -> DB : 9. find()
activate DB
DB --> UserModel : 10. Return nursery documents
deactivate DB
UserModel --> UserService : 11. Return nursery entities
deactivate UserModel
UserService -> UserService : 12. checkDatabaseError()
activate UserService
deactivate UserService
opt database error
    UserService --> ProfileService : 12.1 Return badrequest
    ProfileService --> Controller : 12.2 Return error response
    Controller --> Route : 12.3 Return error response
    Route --> UI : 12.4 Return error response
    UI --> User : 12.5 Display error message
end
UserService --> ProfileService : 13. Return nursery data
deactivate UserService
ProfileService -> ProfileService : 14. extractLocationData()
activate ProfileService
deactivate ProfileService
ProfileService -> ProfileService : 15. formatMapMarkers()
activate ProfileService
deactivate ProfileService
ProfileService -> ProfileService : 16. mapToMapDTO()
activate ProfileService
deactivate ProfileService
ProfileService --> Controller : 17. Return success + map data
deactivate ProfileService
Controller --> Route : 18. Return success + map data 
deactivate Controller
Route --> UI : 19. Return success + map data 
deactivate Route
UI --> UI : 20. Render map
activate UI
deactivate UI
UI --> UI : 21. Display markers
activate UI
deactivate UI
UI --> User : 22. Display map with markers
deactivate UI
deactivate User

@enduml
