@startuml AuthenticationMiddleware

actor User 
participant ":authMiddleware" as M 
entity ":userModel" as Model 
database "MongoDB" as DB 
hide footbox

activate M
M -> M: 1. Receive authentication token (Bearer token in header)
activate M
deactivate M

M -> M: 2. Check token existence
activate M
deactivate M
opt Token missing
activate User

    M --> User: 2.1 Return Authentication Error (token is missing)
end

M -> M: 3. Verify token (signature, expiration)
activate M
deactivate M
opt Invalid token
    M --> User: 3.1 Return Authentication Error (token is invalid)
end

M -> Model: 4. Check token in blacklist
activate Model
Model -> DB: 5. Query blacklist collection
activate DB
DB --> Model: 6. Blacklist result
deactivate DB
Model --> M: 7. Return blacklist check result
deactivate Model

M -> M: 8. checkTokenIsExistInBlacklist()
activate M
deactivate M
opt Token is blacklisted
    M --> User: 8.1 Return Authentication Error (token is logged out)
end

M -> M: 9. Check user status (active / banned )
activate M
deactivate M
opt User banned/suspended
    M --> User: 9.1 Return Authentication Error (user is banned)
end

M -> M: 10. Check user role & permission
activate M
deactivate M
alt User has required role
    M -> M: 10.1 Continue to next handler
    activate M
deactivate M
else User does not have required role
    M --> User: 10.2 Return Authorization Error (insufficient permissions)
    deactivate User

end

M -> M: 11. Forward request to next handler (Controller / Service)
activate M
deactivate M
deactivate M



@enduml