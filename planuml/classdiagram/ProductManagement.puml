@startuml ProductManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction


' ===== Routes & Middleware =====
class ProductRoute <<control>> {
  +createProduct(req, res): void
  +getAllProducts(req, res): void
  +getProductDetail(req, res): void
  +updateProduct(req, res): void
  +deleteProduct(req, res): void
  +searchProducts(req, res): void
  +filterProducts(req, res): void
  +sortProducts(req, res): void
}

class AuthMiddleware <<control>> {
  +protect(req): UserInfo
}

' ===== Controller =====
class ProductController <<control>> {
  +createProduct(req, res): void
  +getAllProducts(req, res): void
  +getProductDetail(req, res): void
  +updateProduct(req, res): void
  +deleteProduct(req, res): void
  +searchProducts(req, res): void
  +filterProducts(req, res): void
  +sortProducts(req, res): void
}

' ===== Service =====
class ProductService <<service>> {
  +createProduct(data): Product
  +getAllProducts(params): { data: Product[], pagination }
  +getProductById(productId): Product
  +updateProduct(productId, data): Product
  +deleteProduct(productId): Product
  +searchProducts(params): { data: Product[], pagination }
  +filterProducts(params): { data: Product[], pagination }
  +sortProducts(params): { data: Product[], pagination }
}

' ===== Models =====
class ProductModel <<model>> {
  +find(filter): Product[]
  +findByIdAndUpdate(id, update, options): Product
  +findByIdAndDelete(id): Product
  +countDocuments(filter): number
}

class ProductImageModel <<model>> {
  +find(filter): ProductImage[]
  +deleteMany(filter): void
  +create(doc): ProductImage
}

class TypeProductModel <<model>> {
  +findById(id): TypeProduct
}

' ===== Entities =====
class Product <<entity>> {
  +_id: ObjectId
  +user_id: ObjectId
  +type_id: ObjectId
  +name: string
  +description: string
  +price: number
  +origin: string
  +weight: number
  +images: ProductImage[]
  +view_count: number
  +rating: number
  +harvest_start_date: Date
  +harvest_end_date: Date
  +status: string  ' active | inactive
  +created_at: Date
  +updated_at: Date
}

class ProductImage <<entity>> {
  +_id: ObjectId
  +product_id: ObjectId
  +url: string
  +created_at: Date
  +updated_at: Date
}

class TypeProduct <<entity>> {
  +_id: ObjectId
  +name: string
  +description: string
  +created_at: Date
  +updated_at: Date
}

class User <<entity>> {
  +_id: ObjectId
  +full_name: string
  +avatar: string
}

class Database <<database>>

' ===== Relationships =====
ProductRoute --> AuthMiddleware : uses (create/update/delete)
ProductRoute --> ProductController : calls handlers

ProductController --> ProductService : orchestration

ProductService --> ProductModel : persistence
ProductService --> ProductImageModel : manage images
ProductService --> TypeProductModel : validate type

ProductModel --> Database : queries
ProductImageModel --> Database : queries
TypeProductModel --> Database : queries

Product "1" o-- "0..*" ProductImage
Product --> TypeProduct
Product --> User

@enduml
