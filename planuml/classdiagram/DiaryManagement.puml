@startuml DiaryManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction


' ===== Routes & Middleware =====
class DiaryRoute <<control>> {
  +getDiariesByUser(req, res): void
  +createDiary(req, res): void
  +getDiaryDetails(req, res): void
  +updateDiary(req, res): void
  +finishDiary(req, res): void
  +deleteDiary(req, res): void
  +addDiaryStep(req, res): void
  +updateDiaryStep(req, res): void
  +deleteDiaryStep(req, res): void
  +statisticsDiary(req, res): void
}

class AuthMiddleware <<control>> {
  +protect(req): UserInfo
}

class AuthorizationMiddleware <<control>> {
  +isFarmer(req): void
}

' ===== Controllers =====
class DiaryController <<control>> {
  +getDiariesByUser(req, res): void
  +createDiary(req, res): void
  +updateDiary(req, res): void
  +finishDiary(req, res): void
  +getDiaryDetails(req, res): void
  +deleteDiary(req, res): void
  +getStepsByDiaryId(req, res): void
  +addDiaryStep(req, res): void
  +updateDiaryStep(req, res): void
  +deleteDiaryStep(req, res): void
  +statisticsDiary(req, res): void
}

' ===== Services =====
class DiaryService <<service>> {
  +getDiariesByUser(filter): Diary[]
  +createDiary(data): Diary
  +updateDiary(diaryId, data): Diary
  +finishDiary(diaryId, data): Diary
  +getDiaryDetails(diaryId): DiaryWithStages
  +deleteDiary(diaryId): Diary
  +getStepsByDiaryId(diaryId): DiaryStep[]
  +updateDiaryStep(stepId, data): DiaryStep
  +addDiaryStep(diaryId, data): DiaryStep
  +deleteDiaryStep(stepId): DiaryStep
  +statisticsDiary(diaryId): DiaryStatistics
}

' ===== Models =====
class DiaryModel <<model>> {
  +find(query): Diary[]
  +findById(id): Diary
  +findByIdAndUpdate(id, update): Diary
  +findByIdAndDelete(id): Diary
}

class DiaryStepModel <<model>> {
  +find(query): DiaryStep[]
  +findByIdAndUpdate(id, update): DiaryStep
  +findByIdAndDelete(id): DiaryStep
  +create(doc): DiaryStep
}

class StepModel <<model>> {
  +find(query): Step[]
}

' ===== Entities =====
class Diary <<entity>> {
  +_id: ObjectId
  +user_id: ObjectId
  +garden_id: ObjectId
  +title: string
  +description: string
  +crop_type: string
  +status: string  ' In progressing | Completed
  +start_date: Date
  +end_date: Date
  +weight_durian: number
  +price: number
  +created_at: Date
  +updated_at: Date
}

class DiaryStep <<entity>> {
  +_id: ObjectId
  +diary_id: ObjectId
  +stage_id: ObjectId
  +step_name: string
  +description: string
  +cost: number
  +image: string
  +action_date: Date
  +created_at: Date
  +updated_at: Date
}

class Step <<entity>> {
  +_id: ObjectId
  +parent_id: ObjectId
  +title: string
  +description: string
  +order_index: number
  +created_at: Date
  +updated_at: Date
}

class DiaryStatistics <<datatype>> {
  +diary_id: ObjectId
  +total_cost: number
  +total_revenue: number
  +profit: number
}

class Database <<database>>

' ===== Relationships =====
DiaryRoute --> AuthMiddleware : uses
DiaryRoute --> AuthorizationMiddleware : uses (for list)
DiaryRoute --> DiaryController : calls handlers

DiaryController --> DiaryService : orchestration

DiaryService --> DiaryModel : persistence
DiaryService --> DiaryStepModel : persistence
DiaryService --> StepModel : read templates

DiaryModel --> Database : queries
DiaryStepModel --> Database : queries
StepModel --> Database : queries

Diary "1" o-- "0..*" DiaryStep
Step "1" o-- "0..*" Step : children
DiaryStep --> Step : references stage

@enduml
