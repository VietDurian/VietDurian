@startuml GardenManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction


' ===== Boundaries & Controllers =====
class GardenRoute <<control>> {
	+getMap(req, res): void
	+getGardenDetails(req, res): void
	+getUserGardens(req, res): void
	+postGarden(req, res): void
	+patchGarden(req, res): void
	+deleteGarden(req, res): void
}

class AuthMiddleware <<control>> {
	+protect(req): UserInfo
}

class AuthorizationMiddleware <<control>> {
	+isAdmin(req): void
	+isFarmer(req): void
}

class GardenController <<control>> {
	+viewMap(req, res): void
	+getGardenDetails(req, res): void
	+getUserGardens(req, res): void
	+registerGarden(req, res): void
	+editGarden(req, res): void
	+deleteGarden(req, res): void
}

' ===== Services =====
class GardenService <<service>> {
	+getAllGardens(): Garden[]
	+getGardensByUser(userId: ObjectId): Garden[]
	+getGardenById(gardenId: ObjectId): Garden
	+createGarden(userId: ObjectId, data): Garden
	+updateGarden(gardenId: ObjectId, data): Garden
	+deleteGarden(gardenId: ObjectId): Garden
}

class CloudinaryClient <<external>> {
	+upload(image): string
}

' ===== Models =====
class GardenModel <<model>> {
	+find(query): Garden[]
	+findById(id): Garden
	+create(doc): Garden
	+findByIdAndUpdate(id, update): Garden
	+findByIdAndDelete(id): Garden
}

class UserModel <<model>> {
	+findById(id): User
}

' ===== Entities =====
class Garden <<entity>> {
	+_id: ObjectId
	+user_id: ObjectId
	+name: string
	+crop_type: string
	+area: number
	+location: string
	+longitude: number
	+latitude: number
	+description: string
	+image: string
	+created_at: Date
	+updated_at: Date
}

class User <<entity>> {
	+_id: ObjectId
	+full_name: string
	+avatar: string
}

class Database <<database>>

' ===== Relationships =====
GardenRoute --> AuthMiddleware : uses
GardenRoute --> AuthorizationMiddleware : uses
GardenRoute --> GardenController : calls handlers

GardenController --> GardenService : orchestration

GardenService --> GardenModel : persistence
GardenService --> CloudinaryClient : uploads images

GardenModel --> Database : queries

Garden "many" o-- "1" User
GardenModel --> UserModel : populate user

@enduml
