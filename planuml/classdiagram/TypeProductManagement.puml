@startuml TypeProductManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

' ==============================
' ========== ROUTE =============
' ==============================

class TypeProductRoute <<control>> {
    +createTypeProduct(req, res): void
    +getAllTypeProducts(req, res): void
    +updateTypeProduct(req, res): void
    +deleteTypeProduct(req, res): void
    +searchTypeProducts(req, res): void
    +sortTypeProducts(req, res): void
}

' ==============================
' ======= CONTROLLER ===========
' ==============================

class TypeProductController <<control>> {
    +createTypeProduct(req, res): void
    +getAllTypeProducts(req, res): void
    +updateTypeProduct(req, res): void
    +deleteTypeProduct(req, res): void
    +searchTypeProducts(req, res): void
    +sortTypeProducts(req, res): void
}

' ==============================
' ========= SERVICE ============
' ==============================

class TypeProductService <<service>> {
    +createTypeProduct(data): TypeProduct
    +getAllTypeProducts(params): { data: TypeProduct[], pagination }
    +updateTypeProduct(typeProductId, data): TypeProduct
    +deleteTypeProduct(typeProductId): TypeProduct
    +searchTypeProducts(params): { data: TypeProduct[], pagination }
    +sortTypeProducts(params): { data: TypeProduct[], pagination }
}

' ==============================
' ========= REPOSITORY =========
' ==============================

class TypeProductModel <<repository>> {
    +find(filter): TypeProduct[]
    +countDocuments(filter): number
    +findByIdAndUpdate(id, update, options): TypeProduct
    +findByIdAndDelete(id): TypeProduct
    +save(): TypeProduct
}

' ==============================
' ========== ENTITY ============
' ==============================

class TypeProduct <<entity>> {
    +_id: ObjectId
    +name: string
    +description: string
    +created_at: Date
    +updated_at: Date
}

class Product <<entity>> {
    +_id: ObjectId
    +type_ids: ObjectId[]
}

class Database <<database>>

' ==============================
' ===== RELATIONSHIPS ==========
' ==============================

TypeProductRoute --> TypeProductController : calls
TypeProductController --> TypeProductService : uses
TypeProductService --> TypeProductModel : uses

TypeProductModel --> Database : queries

Product "1" o-- "0..*" TypeProduct : categorizes

@enduml