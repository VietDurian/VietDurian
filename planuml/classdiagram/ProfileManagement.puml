@startuml ProfileManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title Profile Management Class Diagram (backend aligned)

class ProfilePage <<boundary>> {
  +validateInput(): void
  +showError(message): void
  +showSuccess(message): void
  +displayProfile(u: User): void
  +displayPublicProfile(u: User): void
  +displayServiceProviderProfile(p: ServiceProviderProfile): void
}

class ProfileRoute <<control>> {
  +getMe(req, res): void
  +putUpdate(req, res): void
  +getPublic(userId, req, res): void
}

class AuthMiddleware <<control>> {
  +protect(req): UserInfo
}

class AuthorizationMiddleware <<control>> {
  +hasRole(role): void
}

class ProfileController <<control>> {
  +getProfile(req, res): void
  +updateProfile(req, res): void
  +getPublicProfile(req, res): void
}

class ServiceProviderProfileController <<control>> {
  +addCapabilityProfile(req, res): void
  +updateCapabilityProfile(req, res): void
}

class ProfileService <<service>> {
  +getProfile(userId): User
  +updateProfile(userId, profileData): User
  +getPublicProfile(userId): User
}

class ServiceProviderProfileService <<service>> {
  +addCapabilityProfile(userId, data): ServiceProviderProfile
  +updateCapabilityProfile(userId, data): ServiceProviderProfile
}

class UserModel <<model>> {
  +findById(userId): User
  +findByIdAndUpdate(userId, data): User
}

class ServiceProviderProfileModel <<model>> {
  +findOne(query): ServiceProviderProfile
  +create(doc): ServiceProviderProfile
  +findOneAndUpdate(query, update): ServiceProviderProfile
}

class User <<entity>> {
  +_id: ObjectId
  +full_name: string
  +email: string
  +password: string
  +phone: string
  +avatar: string
  +role: string
  +is_banned: bool
  +is_verified: bool
  +created_at: Date
  +updated_at: Date
}

class ServiceProviderProfile <<entity>> {
  +user_id: ObjectId
  +business_name: string
  +services: string
  +service_areas: string
  +experience_year: number
  +contact_phone: string
  +description: string
  +created_at: Date
  +updated_at: Date
}

class Database <<database>>

ProfilePage --> ProfileRoute : uses
ProfileRoute --> AuthMiddleware : uses

AuthMiddleware --> ProfileController : forwards userInfo
AuthMiddleware --> ServiceProviderProfileController : forwards userInfo

ProfileRoute --> ProfileController : calls handlers

ServiceProviderProfileController --> AuthorizationMiddleware : requires role

ProfileController --> ProfileService : orchestration
ServiceProviderProfileController --> ServiceProviderProfileService : orchestration

ProfileService --> UserModel : persistence
ServiceProviderProfileService --> ServiceProviderProfileModel : persistence

UserModel --> Database : queries
ServiceProviderProfileModel --> Database : queries

@enduml
