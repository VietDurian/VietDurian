@startuml
skinparam classAttributeIconSize 0
left to right direction


class User {
  +Id: string
  +Email: string
  +PasswordHash: string
  +Verified: bool
}

class ResetToken {
  +Token: string
  +UserId: string
  +ExpiresAt: DateTime
  +UsedAt: DateTime
}

class OtpCode {
  +Code: string
  +UserId: string
  +ExpiresAt: DateTime
  +UsedAt: DateTime
}

class Session {
  +RefreshToken: string
  +UserId: string
  +ExpiresAt: DateTime
  +RevokedAt: DateTime
}

class LogoutToken {
  +Token: string
  +UserId: string
  +CreatedAt: DateTime
}

// Simplified: omit AuthResponse

// Simplified: omit GoogleProfile details

// Simplified: omit enums for Role/Status/Provider

' =======================
' ======= SERVICES ======
' =======================

interface IAuthService {
  +RegisterAsync(dto: User)
  +LoginAsync(email: string, password: string)
  +ForgotPasswordAsync(email: string)
  +VerifyOtpAsync(userId: string, code: string)
  +ChangePasswordAsync(userId: string, oldPwd: string, newPwd: string)
  +LogoutAsync(userId: string, refreshToken: string)
  +LoginWithGoogleAsync(idToken: string)
}

class AuthService {
  -_userRepo: IUserRepo
  -_resetTokenRepo: IResetTokenRepo
  -_logoutTokenRepo: ILogoutTokenRepo
  -_hasher: PasswordHasher
  -_tokenService: TokenService
  -_emailService: EmailService
  -_googleOAuth: GoogleOAuthService
  // Methods omitted for brevity
}

IAuthService <|.. AuthService

class PasswordHasher {
  +Hash(plain: string): string
  +Compare(plain: string, hash: string): bool
}

class TokenService {
  +CreateAccessToken(userId: string): string
  +CreateRefreshToken(userId: string): string
  +VerifyRefreshToken(token: string): bool
  +RevokeRefreshToken(token: string): bool
}

class EmailService {
  +SendWelcome(email: string): bool
  +SendPasswordReset(email: string, token: string): bool
}

// Simplified: handle OTP via AuthService + EmailService (no separate OtpService)

class GoogleOAuthService {
  +VerifyIdToken(idToken: string): GoogleProfile
  +GetProfile(code: string): GoogleProfile
}

class AuthController {
  // Methods omitted for brevity
}

' =======================
' ===== REPOSITORIES ====
' =======================

interface IUserRepo {
  +FindByEmailAsync(email: string): User
  +FindByIdAsync(id: string): User
  +CreateAsync(user: User): User
  +UpdateAsync(user: User): User
  +UpdatePasswordAsync(id: string, hash: string): bool
}

class UserRepo {
  -_context: AuthContext
  +FindByEmailAsync(email: string): User
  +FindByIdAsync(id: string): User
  +CreateAsync(user: User): User
  +UpdateAsync(user: User): User
  +UpdatePasswordAsync(id: string, hash: string): bool
}

IUserRepo <|.. UserRepo

interface IResetTokenRepo {
  +CreateAsync(userId: string, token: string, expiresAt: DateTime): ResetToken
  +FindByTokenAsync(token: string): ResetToken
  +InvalidateAsync(token: string): bool
}

class ResetTokenRepo {
  -_context: AuthContext
  +CreateAsync(userId: string, token: string, expiresAt: DateTime): ResetToken
  +FindByTokenAsync(token: string): ResetToken
  +InvalidateAsync(token: string): bool
}

IResetTokenRepo <|.. ResetTokenRepo

// Simplified: omit dedicated OTP repo; keep OtpCode entity only

interface ILogoutTokenRepo {
  +AddAsync(token: string, userId: string): LogoutToken
}

class LogoutTokenRepo {
  -_context: AuthContext
  +AddAsync(token: string, userId: string): LogoutToken
}

ILogoutTokenRepo <|.. LogoutTokenRepo

class AuthContext

' =======================
' ===== RELATIONSHIPS ===
' =======================

AuthController --> IAuthService
AuthService --> IUserRepo
AuthService --> IResetTokenRepo
AuthService --> ILogoutTokenRepo
AuthService --> PasswordHasher
AuthService --> TokenService
AuthService --> EmailService
AuthService --> GoogleOAuthService

UserRepo --> AuthContext
ResetTokenRepo --> AuthContext
LogoutTokenRepo --> AuthContext

UserRepo "1" o-- "many" User
ResetTokenRepo "1" o-- "many" ResetToken
TokenService "1" o-- "many" Session
LogoutTokenRepo "1" o-- "many" LogoutToken

// Simplified relationships: omit DTO links

@enduml