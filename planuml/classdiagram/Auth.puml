@startuml
skinparam classAttributeIconSize 0
left to right direction

' =======================
' ======= ENTITIES ======
' =======================

class User {
  +_id: ObjectId
  +full_name: string
  +email: string
  +password: string  ' hashed via pre-save
  +phone: string
  +avatar: string
  +role: string  ' trader | admin | serviceProvider | contentExpert | farmer
  +is_banned: bool
  +is_verified: bool
  +created_at: DateTime
  +updated_at: DateTime
}

 ' ResetToken not implemented in backend (uses OTP + short-lived JWT)

class OtpCode {
  +code: string
  +user_id: ObjectId
  +purpose: string  ' verify_account | forgot_password
  +is_used: bool
  +expires_at: DateTime
  +created_at: DateTime
}

 ' Session/refresh tokens not implemented in backend

class LogoutToken {
  +token: string
  +user_id: ObjectId
  +expires_at: DateTime
  +created_at: DateTime
}

class PermissionAccount {
  +user_id: ObjectId
  +requested_role: string
  +description: string
  +document: string
  +status: string  ' pending | approved | rejected
  +created_at: DateTime
}

' =======================
' ===== CONTROLLERS =====
' =======================

class AuthController {
  +Register()
  +VerifyEmail()
  +Login()
  +Logout()
  +ForgotPassword()
  +VerifyResetOtp()
  +ResetPassword()
  +GoogleLogin()
  +ChangePassword()
  +CheckAuth()
}

' =======================
' ======= SERVICES ======
' =======================

interface IAuthService {
  +register(userData): { user, token, otp }
  +verifyEmail(email: string, otp: string): { user }
  +login(email: string, password: string): { user, token }
  +logout(userId: ObjectId, token: string): bool
  +forgotPassword(email: string): { message }
  +verifyResetOtp(email: string, otp: string): { resetToken }
  +resetPasswordWithToken(token: string, newPassword: string): { message }
  +googleLogin(idToken: string): { user, token }
  +changePassword(userId: ObjectId, currentPassword: string, newPassword: string): bool
}

class AuthService {
  -_userModel: User
  -_otpModel: OtpCode
  -_logoutTokenModel: LogoutToken
  -_permissionAccountModel: PermissionAccount
  -_jwtService: TokenService
  -_googleClient: GoogleOAuthService
}

IAuthService <|.. AuthService

 ' Password hashing handled in User model pre-save

class TokenService {
  +generateToken(userId: ObjectId): string
  +verifyToken(token: string): any
}

 ' AuthService sends verification/reset emails internally via nodemailer

class GoogleOAuthService {
  +VerifyIdToken(idToken: string): string
}

 ' Backend uses Mongoose models directly (no repository pattern)

' =======================
' ===== RELATIONSHIPS ===
' =======================

User "1" o-- "0..*" OtpCode
User "1" o-- "0..*" LogoutToken
User "1" o-- "0..*" PermissionAccount

AuthController --> IAuthService

AuthService --> TokenService
AuthService --> GoogleOAuthService
AuthService --> User
AuthService --> OtpCode
AuthService --> LogoutToken
AuthService --> PermissionAccount

 ' (no repository context)

@enduml
