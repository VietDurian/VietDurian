@startuml UserManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title User Management Class Diagram (from sequences)

class UserManagementPage <<boundary>> {
  +validateInput(): void
  +showError(message): void
  +showSuccess(message): void
  +displayUserList(list: List<UserDTO>): void
  +displayUserDetail(user: UserDetailDTO): void
}

class UserManagementRoute <<control>> {
  +getList(req, res): void
  +getDetail(userId, req, res): void
  +putBlockStatus(userId, status, req, res): void
  +search(keyword, req, res): void
  +filter(filters, req, res): void
  +sort(field, order, req, res): void
}

class AuthMiddleware <<control>> {
  +authenticateUser(req): UserInfo
  +authorizeRole(roles): void
}

class UserManagementController <<control>> {
  +handleGetUserList(userInfo): void
  +handleGetUserDetail(userInfo, userId): void
  +handleBlockUnblockUser(userInfo, userId, status): void
  +handleSearchUser(userInfo, keyword): void
  +handleFilterUser(userInfo, filters): void
  +handleSortUser(userInfo, field, order): void
}

class UserManagementService <<service>> {
  +getUserList(): List<UserDTO>
  +getUserDetail(userId): UserDetailDTO
  +blockUnblockUser(userId, status): UserDTO
  +searchUser(keyword): List<UserDTO>
  +filterUser(filters): List<UserDTO>
  +sortUser(field, order): List<UserDTO>
  +checkDatabaseError(error): void
  +checkNotFound(entity): void
  +mapToUserDTO(user: User): UserDTO
  +mapToUserDTOList(users: List<User>): List<UserDTO>
  +mapToUserDetailDTO(user: User): UserDetailDTO
}

class UserManagementModel <<model>> {
  +findAllUsers(): List<User>
  +findById(userId): User
  +updateBlockStatus(userId, status): User
  +findByKeyword(keyword): List<User>
  +findByFilters(filters): List<User>
  +findWithSort(field, order): List<User>
}

class User <<entity>> {
  +id: string
  +email: string
  +name: string
  +role: Role
  +status: Status
  +createdAt: Date
  +updatedAt: Date
}

class UserDTO <<datatype>> {
  +id: string
  +email: string
  +name: string
  +role: Role
  +status: Status
}

class UserDetailDTO <<datatype>> {
  +id: string
  +email: string
  +name: string
  +role: Role
  +status: Status
  +createdAt: Date
  +updatedAt: Date
}

enum Role {
  ADMIN
  USER
}

enum Status {
  ACTIVE
  BLOCKED
  PENDING
}

database DB as Database

UserManagementPage --> UserManagementRoute : uses
UserManagementRoute --> AuthMiddleware : uses
AuthMiddleware --> UserManagementController : forwards userInfo
UserManagementRoute --> UserManagementController : calls handlers
UserManagementController --> UserManagementService : orchestration
UserManagementService --> UserManagementModel : persistence
UserManagementModel --> DB : queries
UserManagementService --> UserDTO : returns
UserManagementService --> UserDetailDTO : returns
UserManagementModel --> User : entity

@enduml