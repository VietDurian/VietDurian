@startuml UserManagement
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction


' ===== Routes & Middleware =====
class UserRoute <<control>> {
  +getAllUsers(req, res): void
  +getUserById(req, res): void
  +toggleBan(req, res): void
  +searchUser(req, res): void
  +filterUsers(req, res): void
  +sortUsers(req, res): void
}

class AuthMiddleware <<control>> {
  +protect(req): UserInfo
}

class AuthorizationMiddleware <<control>> {
  +isAdmin(req): void
}

' ===== Controller =====
class UserController <<control>> {
  +getAllUsers(req, res): void
  +getUserById(req, res): void
  +toggleBan(req, res): void
  +searchUser(req, res): void
  +filterUsers(req, res): void
  +sortUsers(req, res): void
}

' ===== Service =====
class UserService <<service>> {
  +getAllUsers(page, limit): PaginatedUsers
  +getUserById(id): User
  +banUser(id, is_banned): User
  +searchUsers(keyword): User[]
  +filterUsers(filters): User[]
  +sortUsers(sort): User[]
}

class PaginatedUsers <<datatype>> {
  +users: User[]
  +total: number
  +page: number
  +totalPages: number
}

' ===== Model =====
class UserModel <<model>> {
  +find(query): User[]
  +findById(id): User
  +findByIdAndUpdate(id, update, options): User
  +countDocuments(): number
}

' ===== Entity =====
class User <<entity>> {
  +_id: ObjectId
  +full_name: string
  +email: string
  +password: string
  +phone: string
  +avatar: string
  +role: string
  +is_banned: bool
  +is_verified: bool
  +created_at: Date
  +updated_at: Date
}

class Database <<database>>

' ===== Relationships =====
UserRoute --> AuthMiddleware : uses
UserRoute --> AuthorizationMiddleware : uses
UserRoute --> UserController : calls handlers

UserController --> UserService : orchestration
UserService --> UserModel : persistence
UserModel --> Database : queries

@enduml